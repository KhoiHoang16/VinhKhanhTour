@using VinhKhanhTour.CMS.Services
@using VinhKhanhTour.Shared.Models
@inject PoiService PoiService

<div class="sidebar-container">
    <div class="sidebar-header">
        <div class="logo-icon">🍜</div>
        <div class="logo-text">
            <div class="title">Vĩnh Khánh</div>
            <div class="subtitle">Content Management</div>
        </div>
    </div>

    <!-- Mobile Toggler -->
    <input type="checkbox" title="Navigation menu" class="navbar-toggler" />

    <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler')?.click()">
        <nav class="nav flex-column sidebar-nav">
            <div class="nav-item">
                <NavLink class="nav-link" href="analytics" Match="NavLinkMatch.All">
                    <span class="nav-icon">📊</span> Tổng quan
                </NavLink>
            </div>

            <div class="nav-item">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="nav-icon">📍</span> Quản lý POI
                </NavLink>
            </div>

            <div class="nav-item">
                <NavLink class="nav-link" href="translations">
                    <span class="nav-icon">🌐</span> Bản dịch
                </NavLink>
            </div>

            <div class="nav-item">
                <NavLink class="nav-link" href="audio">
                    <span class="nav-icon">🎵</span> Audio
                </NavLink>
            </div>

            <div class="nav-item">
                <NavLink class="nav-link" href="history">
                    <span class="nav-icon">📋</span> Lịch sử
                </NavLink>
            </div>

            <AuthorizeView Roles="Admin">
                <Authorized>
                    <div class="nav-item">
                        <NavLink class="nav-link" href="tours">
                            <span class="nav-icon">🗺️</span> Quản lý Tour
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="users">
                            <span class="nav-icon">👥</span> Quản lý Chủ quán
                        </NavLink>
                    </div>

                </Authorized>
            </AuthorizeView>
            
            <div class="nav-item">
                <NavLink class="nav-link" href="qrcode">
                    <span class="nav-icon">📱</span> QR Code
                </NavLink>
            </div>
        </nav>
    </div>

    <div class="sidebar-footer">
        <div class="user-profile">
            <AuthorizeView>
                <Authorized>
                    <div class="avatar">@(context.User.Identity?.Name?.FirstOrDefault().ToString().ToUpper() ?? "U")</div>
                    <div class="email">@context.User.Identity?.Name</div>
                </Authorized>
            </AuthorizeView>
        </div>
        <a href="/account/logout" class="logout-btn">
            <div class="logout-icon"></div> Đăng xuất
        </a>
    </div>
</div>

<style>
    .sidebar-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        background-color: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border-right: 1px solid rgba(255, 255, 255, 0.05);
        color: #fff;
    }

    .sidebar-header {
        display: flex;
        align-items: center;
        padding: 28px 20px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        margin-bottom: 12px;
    }

    .logo-icon {
        font-size: 32px;
        margin-right: 14px;
        line-height: 1;
        filter: drop-shadow(0 4px 6px rgba(16, 185, 129, 0.3));
    }

    .logo-text {
        display: flex;
        flex-direction: column;
    }

    .logo-text .title {
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 700;
        font-size: 1.35rem;
        background: linear-gradient(135deg, #10b981, #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: -0.5px;
        line-height: 1.2;
    }

    .logo-text .subtitle {
        font-size: 0.75rem;
        color: #94a3b8;
        font-weight: 500;
        font-family: 'Inter', sans-serif;
    }

    .nav-scrollable {
        flex: 1;
        overflow-y: auto;
        padding: 0 16px;
    }

    .nav-scrollable::-webkit-scrollbar {
        width: 4px;
    }
    .nav-scrollable::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.1);
        border-radius: 4px;
    }

    .sidebar-nav {
        gap: 6px;
    }

    .nav-item {
        width: 100%;
        margin-bottom: 4px;
    }

    .nav-item .nav-link {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        color: #94a3b8;
        border-radius: 12px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.3s ease;
        border: 1px solid transparent;
    }

    .nav-item .nav-link .nav-icon {
        font-size: 1.2rem;
        margin-right: 14px;
        width: 24px;
        text-align: center;
        transition: transform 0.3s ease;
    }

    .nav-item .nav-link:hover {
        background: rgba(16, 185, 129, 0.08);
        color: #ffffff;
        border-color: rgba(16, 185, 129, 0.2);
    }
    
    .nav-item .nav-link:hover .nav-icon {
        transform: scale(1.1);
    }

    .nav-item .nav-link.active {
        background: linear-gradient(90deg, rgba(16, 185, 129, 0.15), transparent);
        color: #10b981;
        border-left: 3px solid #10b981;
        border-radius: 4px 12px 12px 4px;
    }

    .sidebar-footer {
        padding: 20px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        background-color: transparent;
    }

    .user-profile {
        display: flex;
        align-items: center;
        margin-bottom: 20px;
    }

    .avatar {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: #fff;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-right: 14px;
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
    }

    .email {
        color: #cbd5e1;
        font-size: 0.85rem;
        font-weight: 500;
    }

    .logout-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 12px;
        background-color: rgba(239, 68, 68, 0.05);
        border: 1px solid rgba(239, 68, 68, 0.15);
        border-radius: 10px;
        color: #f87171;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .logout-btn:hover {
        background-color: rgba(239, 68, 68, 0.15);
        color: #fca5a5;
        border-color: rgba(239, 68, 68, 0.3);
    }

    .logout-icon {
        width: 6px;
        height: 14px;
        background-color: currentColor;
        border-radius: 2px;
        margin-right: 10px;
    }

    /* Mobile settings */
    .navbar-toggler {
        appearance: none;
        cursor: pointer;
        width: 3.5rem;
        height: 2.5rem;
        color: white;
        position: absolute;
        top: 0.5rem;
        right: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%28255, 255, 255, 0.8%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") no-repeat center/1.75rem rgba(255, 255, 255, 0.05);
        border-radius: 0.5rem;
        z-index: 2;
    }

    @@media (min-width: 641px) {
        .navbar-toggler {
            display: none;
        }
    }
    
    @@media (max-width: 640.98px) {
        .nav-scrollable { display: none; }
        .sidebar-footer { display: none; }
        .navbar-toggler:checked ~ .nav-scrollable { display: block; }
        .navbar-toggler:checked ~ .sidebar-footer { display: block; }
        .sidebar-container { height: auto; background-color: rgba(30, 41, 59, 0.95); backdrop-filter: blur(16px); }
    }
</style>

@code {
    private int pendingCount = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            pendingCount = await PoiService.GetPendingCountAsync();
        }
        catch
        {
            // Silently fail — badge just won't show
            pendingCount = 0;
        }
    }
}
