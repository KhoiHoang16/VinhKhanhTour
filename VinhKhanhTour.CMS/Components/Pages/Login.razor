@page "/login"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Components.Authorization
@layout VinhKhanhTour.CMS.Components.Layout.EmptyLayout
@inject NavigationManager NavigationManager

<PageTitle>Đăng Nhập Quản Trị Hệ Thống</PageTitle>

<div class="login-container">
    <div class="login-card">
        <h2>VinhKhanhTour CMS</h2>
        <p class="subtitle">Truy cập bảng điều khiển quản trị</p>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger" style="font-size: 0.9rem;">
                🚨 @ErrorMessage
            </div>
        }

        <form method="post" action="/Account/login">
            <AntiforgeryToken />
            <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
            
            <div class="form-group">
                <label>Tài khoản Quản Trị:</label>
                <input type="text" name="Username" class="form-control" autocomplete="username" required />
            </div>
            
            <div class="form-group mb-4">
                <label>Mật mã:</label>
                <input type="password" name="Password" class="form-control" autocomplete="current-password" required />
            </div>
            
            <button type="submit" class="btn btn-primary w-100 mb-3">
                🔒 Đăng Nhập Hệ Thống
            </button>
            
            <div class="text-center mt-3 border-top pt-3" style="border-color: rgba(255,255,255,0.1) !important;">
                <span style="color: #ccc; font-size: 0.9rem;">Chưa có tài khoản?</span>
                <a href="/register" class="btn btn-outline-warning w-100 mt-2" style="font-weight: 600; padding: 10px;">
                    📝 Đăng Ký Trở Thành Đối Tác
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    body { 
        background-color: #0f172a; 
        color: white; 
        margin: 0;
    }
    .login-container { 
        height: 100vh; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        background: url('/images/vinh_khanh_food_street_banner.jpg') no-repeat center center; 
        background-size: cover; 
    }
    .login-container::before {
        content: "";
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(15, 23, 42, 0.75);
        z-index: 1;
    }
    .login-card { 
        position: relative;
        z-index: 2;
        background: rgba(30, 41, 59, 0.6); 
        padding: 44px; 
        border-radius: 1.25rem; 
        width: 100%; 
        max-width: 420px; 
        box-shadow: 0 12px 48px rgba(0,0,0,0.5); 
        backdrop-filter: blur(24px); 
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255,255,255,0.08);
    }
    h2 { 
        font-family: 'Space Grotesk', sans-serif;
        background: linear-gradient(135deg, #10b981, #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-weight: 800; 
        text-align: center; 
        margin-bottom: 5px;
        font-size: 1.6rem;
    }
    .subtitle { 
        text-align: center; 
        color: #94a3b8; 
        margin-bottom: 32px; 
        font-size: 0.9rem;
        font-family: 'Inter', sans-serif;
    }
    .form-group { 
        margin-bottom: 18px; 
    }
    label { 
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 600; 
        margin-bottom: 8px; 
        color: #e2e8f0; 
        font-size: 0.95rem;
    }
    .form-control { 
        background-color: rgba(15, 23, 42, 0.6); 
        border: 1px solid rgba(255,255,255,0.08); 
        color: white; 
        padding: 14px;
        border-radius: 0.75rem;
        font-family: 'Inter', sans-serif;
        transition: all 0.3s;
    }
    .form-control:focus { 
        background-color: rgba(15, 23, 42, 0.8); 
        border-color: #10b981; 
        color: white; 
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15); 
    }
    .btn-primary { 
        background: linear-gradient(135deg, #10b981, #059669); 
        border: none; 
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 700; 
        padding: 14px; 
        font-size: 1.05rem;
        border-radius: 0.85rem;
        transition: all 0.3s;
        box-shadow: 0 4px 14px rgba(16, 185, 129, 0.3);
        color: white;
    }
    .btn-primary:hover { 
        filter: brightness(1.1);
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(16, 185, 129, 0.45);
    }
</style>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public bool Error { get; set; } = false;

    private string? ErrorMessage => Error ? "Tài khoản hoặc mật khẩu không chính xác." : null;
}
