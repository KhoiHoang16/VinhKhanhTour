@page "/login"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Components.Authorization
@layout VinhKhanhTour.CMS.Components.Layout.EmptyLayout
@inject NavigationManager NavigationManager

<PageTitle>Đăng Nhập Quản Trị Hệ Thống</PageTitle>

<div class="login-container">
    <div class="login-card">
        <h2>VinhKhanhTour CMS</h2>
        <p class="subtitle">Truy cập bảng điều khiển quản trị</p>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger" style="font-size: 0.9rem;">
                🚨 @ErrorMessage
            </div>
        }

        <form method="post" action="/Account/login">
            <AntiforgeryToken />
            <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
            
            <div class="form-group">
                <label>Tài khoản Quản Trị:</label>
                <input type="text" name="Username" class="form-control" autocomplete="username" required />
            </div>
            
            <div class="form-group mb-4">
                <label>Mật mã:</label>
                <input type="password" name="Password" class="form-control" autocomplete="current-password" required />
            </div>
            
            <button type="submit" class="btn btn-primary w-100 mb-3">
                🔒 Đăng Nhập Hệ Thống
            </button>
            
            <div class="text-center mt-3 border-top pt-3" style="border-color: rgba(255,255,255,0.1) !important;">
                <span style="color: #ccc; font-size: 0.9rem;">Chưa có tài khoản?</span>
                <a href="/register" class="btn btn-outline-warning w-100 mt-2" style="font-weight: 600; padding: 10px;">
                    📝 Đăng Ký Trở Thành Đối Tác
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    body { 
        background-color: #121212; 
        color: white; 
        margin: 0;
    }
    .login-container { 
        height: 100vh; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        background: url('/images/vinh_khanh_food_street_banner.jpg') no-repeat center center; 
        background-size: cover; 
    }
    .login-container::before {
        content: "";
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.6);
        z-index: 1;
    }
    .login-card { 
        position: relative;
        z-index: 2;
        background: rgba(30, 30, 30, 0.75); 
        padding: 40px; 
        border-radius: 12px; 
        width: 100%; 
        max-width: 400px; 
        box-shadow: 0 8px 32px rgba(0,0,0,0.8); 
        backdrop-filter: blur(12px); 
        border: 1px solid rgba(255,165,0,0.3);
    }
    h2 { 
        color: #FFA500; 
        font-weight: 800; 
        text-align: center; 
        margin-bottom: 5px;
    }
    .subtitle { 
        text-align: center; 
        color: #ccc; 
        margin-bottom: 30px; 
        font-size: 0.9rem;
    }
    .form-group { 
        margin-bottom: 15px; 
    }
    label { 
        font-weight: 600; 
        margin-bottom: 8px; 
        color: #eee; 
        font-size: 0.95rem;
    }
    .form-control { 
        background-color: rgba(0,0,0,0.5); 
        border: 1px solid #555; 
        color: white; 
        padding: 12px;
    }
    .form-control:focus { 
        background-color: rgba(0,0,0,0.8); 
        border-color: #FFA500; 
        color: white; 
        box-shadow: 0 0 0 0.25rem rgba(255, 165, 0, 0.25); 
    }
    .btn-primary { 
        background-color: #FFA500; 
        border: none; 
        font-weight: bold; 
        padding: 12px; 
        font-size: 1.1rem;
        transition: background-color 0.2s;
    }
    .btn-primary:hover { 
        background-color: #e69500; 
    }
</style>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public bool Error { get; set; } = false;

    private string? ErrorMessage => Error ? "Tài khoản hoặc mật khẩu không chính xác." : null;
}
