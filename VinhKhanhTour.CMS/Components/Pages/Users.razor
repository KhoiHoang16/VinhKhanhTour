@page "/users"
@attribute [Authorize(Roles = "Admin")]
@using VinhKhanhTour.Shared.Models
@using VinhKhanhTour.CMS.Data
@using VinhKhanhTour.CMS.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<CmsDbContext> DbFactory
@inject IEmailService EmailService

<PageTitle>Quản lý Người dùng & Trạng thái</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h3>Quản lý Người dùng</h3>
    <div class="d-flex gap-2">
        <input type="text" class="form-control" placeholder="Tìm kiếm Email, Tên..." @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearch" />
        <button class="btn btn-outline-primary whitespace-nowrap" @onclick="LoadUsers">
            🔄 Làm mới
        </button>
    </div>
</div>

@if (users == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang tải...</span>
        </div>
        <p class="mt-2 text-muted">Đang tải danh sách tài khoản...</p>
    </div>
}
else if (!users.Any())
{
    <div class="alert alert-info">
        Không tìm thấy người dùng nào trong hệ thống.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle custom-table">
            <thead>
                <tr>
                    <th>Trạng thái</th>
                    <th>Người dùng</th>
                    <th>Phân loại</th>
                    <th>Hoạt động cuối</th>
                    <th>Thiết bị / IP</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users)
                {
                    <tr>
                        <td>
                            @if (user.IsOnline)
                            {
                                <div class="d-flex align-items-center">
                                    <span class="status-dot online"></span>
                                    <span class="text-success fw-bold ms-2">Online</span>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center">
                                    <span class="status-dot offline"></span>
                                    <span class="text-muted ms-2">Offline</span>
                                </div>
                            }
                        </td>
                        <td>
                            <div class="fw-bold">@(string.IsNullOrEmpty(user.FullName) ? "Chưa cập nhật" : user.FullName)</div>
                            <small class="text-muted">@user.Email</small>
                            @if (!string.IsNullOrEmpty(user.DisplayName) && user.UserType != "Tourist")
                            {
                                <div class="badge bg-secondary mt-1">@user.DisplayName</div>
                            }
                        </td>
                        <td>
                            @if (user.UserType == "Tourist")
                            {
                                <span class="badge bg-info text-light">Khách du lịch</span>
                            }
                            else if (user.Role == "Admin")
                            {
                                <span class="badge bg-danger">Hệ thống Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Chủ quán (Agency)</span>
                            }
                        </td>
                        <td>
                            @if (user.LastActiveAt.HasValue)
                            {
                                <div class="fw-bold text-light">@GetTimeSince(user.LastActiveAt.Value)</div>
                                <small class="text-muted">@user.LastActiveAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Chưa rõ</span>
                            }
                        </td>
                        <td>
                            <div class="text-truncate" style="max-width: 150px;" title="@user.LastActiveDevice">
                                @(string.IsNullOrEmpty(user.LastActiveDevice) ? "N/A" : user.LastActiveDevice)
                            </div>
                            <small class="text-muted">@(string.IsNullOrEmpty(user.LastActiveIp) ? "N/A" : user.LastActiveIp)</small>
                        </td>
                        <td>
                            @if (user.IsLocked)
                            {
                                <button class="btn btn-sm btn-success w-100 mb-1 fw-bold" @onclick="() => ToggleLock(user)">
                                    🔓 Mở khóa
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger w-100 mb-1" @onclick="() => ToggleLock(user)"
                                        disabled="@(user.Role == "Admin")" title="@(user.Role == "Admin" ? "Không thể khóa Admin" : "Khóa tài khoản")">
                                    🔒 Khóa
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<style>
    .whitespace-nowrap {
        white-space: nowrap;
    }
    .custom-table {
        background-color: rgba(30, 41, 59, 0.55);
        border-radius: 1.25rem;
        overflow: hidden;
        color: #e2e8f0;
        backdrop-filter: blur(24px);
    }
    .custom-table th {
        background-color: rgba(15, 23, 42, 0.5);
        color: #94a3b8;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding: 14px 16px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .custom-table td {
        padding: 14px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        background-color: transparent;
        color: #e2e8f0;
    }
    .custom-table tbody tr:hover td {
        background-color: rgba(16, 185, 129, 0.06);
    }
    .status-dot {
        height: 12px;
        width: 12px;
        border-radius: 50%;
        display: inline-block;
        box-shadow: 0 0 8px rgba(0,0,0,0.5);
    }
    .status-dot.online {
        background-color: #10b981; /* Green */
        box-shadow: 0 0 10px #10b981;
    }
    .status-dot.offline {
        background-color: #64748b; /* Gray */
    }
    .custom-table .text-muted {
        color: #94a3b8 !important; /* Xám sáng để dễ nhìn trên nền tối */
    }
    .custom-table .fw-bold {
        color: #f1f5f9 !important; /* Trắng sáng cho các tiêu đề/tên */
    }
</style>

@code {
    private List<UserViewModel>? users;
    private string searchQuery = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task HandleSearch(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadUsers();
        }
    }

    private async Task LoadUsers()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        // 1. Phân loại AppUsers
        var appUsersQuery = context.AppUsers.AsNoTracking().AsQueryable();
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var search = searchQuery.ToLower();
            appUsersQuery = appUsersQuery.Where(u => u.Username.ToLower().Contains(search) 
                                                  || (u.Email != null && u.Email.ToLower().Contains(search)) 
                                                  || (u.FullName != null && u.FullName.ToLower().Contains(search)));
        }

        var appUsers = await appUsersQuery.Select(u => new UserViewModel
        {
            Id = u.Id,
            Email = u.Email ?? "",
            DisplayName = u.Username,
            FullName = u.FullName,
            Role = u.Role,
            UserType = "AppUser",
            IsLocked = u.IsLocked,
            LastActiveAt = u.LastActiveAt,
            LastActiveIp = u.LastActiveIp,
            LastActiveDevice = u.LastActiveDevice,
            CreatedAt = u.CreatedAt
        }).ToListAsync();

        // 2. Phân loại Tourist
        var touristsQuery = context.Tourists.AsNoTracking().AsQueryable();
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            var search = searchQuery.ToLower();
            touristsQuery = touristsQuery.Where(t => t.Email.ToLower().Contains(search) 
                                                  || (t.FullName != null && t.FullName.ToLower().Contains(search)));
        }

        var tourists = await touristsQuery.Select(t => new UserViewModel
        {
            Id = t.Id,
            Email = t.Email,
            DisplayName = t.FullName ?? t.Email,
            FullName = t.FullName,
            Role = "Tourist",
            UserType = "Tourist",
            IsLocked = t.IsLocked,
            LastActiveAt = t.LastActiveAt,
            LastActiveIp = t.LastActiveIp,
            LastActiveDevice = t.LastActiveDevice,
            CreatedAt = t.CreatedAt
        }).ToListAsync();

        // Combine and Sort
        users = appUsers.Concat(tourists)
            .OrderByDescending(u => u.IsOnline) // Online lên đầu
            .ThenByDescending(u => u.LastActiveAt) // Mới truy cập lên sau
            .ToList();
    }

    private async Task ToggleLock(UserViewModel user)
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        if (user.UserType == "Tourist")
        {
            var tourist = await context.Tourists.FindAsync(user.Id);
            if (tourist != null)
            {
                tourist.IsLocked = !tourist.IsLocked;
                user.IsLocked = tourist.IsLocked;
                await context.SaveChangesAsync();

                if (user.IsLocked && !string.IsNullOrEmpty(user.Email))
                {
                    await EmailService.SendAccountLockedEmailAsync(user.Email, user.FullName ?? "Người dùng");
                }
            }
        }
        else
        {
            var appUser = await context.AppUsers.FindAsync(user.Id);
            if (appUser != null && appUser.Role != "Admin")
            {
                appUser.IsLocked = !appUser.IsLocked;
                user.IsLocked = appUser.IsLocked;
                await context.SaveChangesAsync();

                if (user.IsLocked && !string.IsNullOrEmpty(user.Email))
                {
                    await EmailService.SendAccountLockedEmailAsync(user.Email, user.FullName ?? user.DisplayName);
                }
            }
        }
    }

    private string GetTimeSince(DateTime utcDateTime)
    {
        var timeSpan = DateTime.UtcNow - utcDateTime;
        if (timeSpan.TotalMinutes < 1) return "Vừa truy cập";
        if (timeSpan.TotalMinutes < 60) return $"{(int)timeSpan.TotalMinutes} phút trước";
        if (timeSpan.TotalHours < 24) return $"{(int)timeSpan.TotalHours} giờ trước";
        if (timeSpan.TotalDays < 30) return $"{(int)timeSpan.TotalDays} ngày trước";
        
        return "> 1 tháng trước";
    }

    public class UserViewModel
    {
        public int Id { get; set; }
        public string Email { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public string? FullName { get; set; }
        public string Role { get; set; } = string.Empty;
        public string UserType { get; set; } = string.Empty;
        public bool IsLocked { get; set; }
        public DateTime? LastActiveAt { get; set; }
        public string? LastActiveIp { get; set; }
        public string? LastActiveDevice { get; set; }
        public DateTime CreatedAt { get; set; }

        public bool IsOnline => LastActiveAt.HasValue && LastActiveAt.Value > DateTime.UtcNow.AddSeconds(-15);
    }
}
