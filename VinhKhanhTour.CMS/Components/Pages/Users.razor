@page "/users"
@attribute [Authorize(Roles = "Admin")]
@using VinhKhanhTour.Shared.Models
@using VinhKhanhTour.CMS.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<CmsDbContext> DbFactory

<PageTitle>Quản lý tài khoản Chủ Quán</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h3>Tài khoản Chủ quán</h3>
    <button class="btn btn-outline-primary" @onclick="LoadUsers">
        🔄 Làm mới
    </button>
</div>

@if (users == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang tải...</span>
        </div>
        <p class="mt-2 text-muted">Đang tải danh sách tài khoản...</p>
    </div>
}
else if (!users.Any())
{
    <div class="alert alert-info">
        Chưa có tài khoản chủ quán nào trong hệ thống.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle custom-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Họ & Tên</th>
                    <th>Tên đăng nhập / SĐT</th>
                    <th>Email</th>
                    <th>Ngày đăng ký</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users)
                {
                    <tr>
                        <td><strong>#@user.Id</strong></td>
                        <td>@user.FullName</td>
                        <td>
                            <div>@user.Username</div>
                            @if (!string.IsNullOrEmpty(user.PhoneNumber) && user.PhoneNumber != user.Username)
                            {
                                <small class="text-muted">@user.PhoneNumber</small>
                            }
                        </td>
                        <td>@user.Email</td>
                        <td>@user.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            @if (user.ForcePasswordChange)
                            {
                                <span class="badge bg-warning text-dark">Chưa đổi mật khẩu</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Đang hoạt động</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-warning" @onclick="() => ResetPassword(user)" title="Reset mật khẩu về 123">
                                🔑 Reset Pass
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<style>
    .custom-table {
        background-color: rgba(30, 41, 59, 0.55);
        border-radius: 1.25rem;
        overflow: hidden;
        color: #e2e8f0;
        backdrop-filter: blur(24px);
    }
    .custom-table th {
        background-color: rgba(15, 23, 42, 0.5);
        color: #94a3b8;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding: 14px 16px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .custom-table td {
        padding: 14px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        background-color: transparent;
        color: #e2e8f0;
    }
    .custom-table tbody tr:hover td {
        background-color: rgba(16, 185, 129, 0.06);
    }
    .badge {
        font-weight: 600;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
    }
</style>

@code {
    private List<AppUser>? users;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        users = null;
        StateHasChanged();

        using var dbContext = await DbFactory.CreateDbContextAsync();
        users = await dbContext.AppUsers
            .Where(u => u.Role != "Admin")
            .OrderByDescending(u => u.CreatedAt)
            .ToListAsync();
            
        StateHasChanged();
    }

    private async Task ResetPassword(AppUser user)
    {
        // Simple client side reset for admin
        user.PasswordHash = BCrypt.Net.BCrypt.HashPassword("123");
        user.ForcePasswordChange = true;
        
        using var dbContext = await DbFactory.CreateDbContextAsync();
        dbContext.AppUsers.Update(user);
        await dbContext.SaveChangesAsync();
        
        await LoadUsers();
    }
}
