@page "/admin/users/tracking"
@implements IDisposable
@inject VinhKhanhTour.CMS.Services.ActiveSessionTracker Tracker
@using System.Threading

<PageTitle>Theo dõi hoạt động</PageTitle>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-white fw-bold mb-1">Theo dõi hoạt động</h2>
            <p class="text-secondary mb-0">Giám sát người dùng và khách ẩn danh theo thời gian thực (Cập nhật mỗi 15s)</p>
        </div>
        <div class="d-flex align-items-center">
            <div class="badge-glass me-3">
                <span class="pulse-indicator bg-success me-2"></span>
                <span>Live Data</span>
            </div>
            <div class="text-white bg-glass px-3 py-2 rounded-3 text-center">
                <div class="fs-4 fw-bold text-success" style="line-height: 1;">@_activeUsers.Count</div>
                <div class="text-uppercase small text-secondary" style="font-size: 0.7rem;">Online</div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="card card-glass border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-glass align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Thông tin người dùng</th>
                            <th>Trạng thái</th>
                            <th>Dấu vết (IP & Thiết bị)</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_isLoading)
                        {
                            @for (int i = 0; i < 3; i++)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center skeleton-row">
                                            <div class="skeleton-avatar me-3"></div>
                                            <div>
                                                <div class="skeleton-text skeleton-title mb-2"></div>
                                                <div class="skeleton-text skeleton-subtitle"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td><div class="skeleton-text skeleton-col"></div></td>
                                    <td>
                                        <div class="skeleton-text skeleton-col mb-2" style="width: 140px;"></div>
                                        <div class="skeleton-text skeleton-col" style="width: 200px;"></div>
                                    </td>
                                    <td class="text-end pe-4"><div class="skeleton-btn ms-auto"></div></td>
                                </tr>
                            }
                        }
                        else if (_activeUsers.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <i class="bi bi-person-x text-secondary" style="font-size: 3rem; margin-bottom: 1rem; display: block;"></i>
                                    <h5 class="text-white">Không có kết nối</h5>
                                    <p class="text-secondary">Chưa ghi nhận người dùng hoặc khách ẩn danh nào đang hoạt động.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var session in _activeUsers)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            @if (session.UserType == "Guest")
                                            {
                                                <div class="avatar-glass bg-gradient-warning me-3 d-flex align-items-center justify-content-center">
                                                    <i class="bi bi-qr-code-scan fs-5 text-dark"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-warning d-flex align-items-center">
                                                        <span>Khách vãng lai</span>
                                                        <span class="fs-6 ms-2">👻</span>
                                                    </div>
                                                    <div class="text-secondary small font-monospace mt-1">
                                                        <i class="bi bi-laptop ps-1 pe-1"></i> ID: @TruncateId(session.Identifier)
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <img src="@(string.IsNullOrEmpty(session.Avatar) ? "/images/default-avatar.png" : session.Avatar)" 
                                                     class="avatar-glass me-3" style="object-fit: cover;" alt="avatar" />
                                                <div>
                                                    <div class="fw-bold text-white">@session.DisplayName</div>
                                                    <div class="text-secondary small mt-1 d-flex align-items-center">
                                                        <span class="badge bg-secondary me-2">@session.UserType</span>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <span class="status-indicator bg-success me-2"></span>
                                            <span class="text-success fw-semibold">Online</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="text-white small mb-1">
                                            <i class="bi bi-globe2 text-secondary me-2"></i> @session.IpAddress
                                        </div>
                                        <div class="text-secondary small text-truncate" style="max-width: 250px;" title="@session.UserAgent">
                                            <i class="bi bi-browser-chrome text-secondary me-2"></i> @TruncateUserAgent(session.UserAgent)
                                        </div>
                                    </td>
                                    <td class="text-end pe-4">
                                        @if (session.UserType == "Guest")
                                        {
                                            <button class="btn btn-action-glass disabled" title="Không thể khóa khách vãng lai">
                                                <i class="bi bi-lock text-secondary"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-action-glass text-light action-hover-danger" title="Khóa tài khoản">
                                                <i class="bi bi-lock-fill"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* Modern Glassmorphism Styles for Track Dashboard */
    .bg-glass {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
    }
    
    .card-glass {
        background: rgba(18, 20, 24, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(16px);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    .table-glass {
        --bs-table-bg: transparent;
        --bs-table-color: #fff;
        --bs-table-hover-bg: rgba(255, 255, 255, 0.04);
        --bs-table-border-color: rgba(255, 255, 255, 0.05);
    }
    
    .table-glass thead th {
        background-color: rgba(255, 255, 255, 0.02);
        color: #a0aab5;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        border-bottom: 2px solid rgba(255, 255, 255, 0.1);
        padding: 1rem 0.75rem;
    }
    
    .table-glass tbody td {
        padding: 1rem 0.75rem;
        vertical-align: middle;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .avatar-glass {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        border: 2px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
    }
    
    .bg-gradient-warning {
        background: linear-gradient(135deg, #ffd700, #ff8c00);
    }

    .badge-glass {
        background: rgba(40, 167, 69, 0.15);
        border: 1px solid rgba(40, 167, 69, 0.3);
        color: #28a745;
        padding: 0.4rem 0.8rem;
        border-radius: 50rem;
        font-size: 0.8rem;
        font-weight: 600;
        display: flex;
        align-items: center;
    }

    .status-indicator {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        box-shadow: 0 0 8px rgba(40, 167, 69, 0.8);
    }

    .pulse-indicator {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(40, 167, 69, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(40, 167, 69, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(40, 167, 69, 0); }
    }

    .btn-action-glass {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        width: 36px;
        height: 36px;
        padding: 0;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }
    
    .btn-action-glass:hover:not(.disabled) {
        background: rgba(255, 255, 255, 0.15);
        transform: translateY(-2px);
    }
    
    .action-hover-danger:hover {
        background: rgba(220, 53, 69, 0.2) !important;
        border-color: rgba(220, 53, 69, 0.5) !important;
        color: #ff6b6b !important;
    }
    
    .btn-action-glass.disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    /* Skeleton Loading Animations */
    .skeleton-text {
        background: linear-gradient(90deg, rgba(255,255,255,0.05) 25%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.05) 75%);
        background-size: 200% 100%;
        animation: loading 1.5s infinite;
        border-radius: 4px;
        height: 12px;
    }
    
    .skeleton-avatar {
        background: linear-gradient(90deg, rgba(255,255,255,0.05) 25%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.05) 75%);
        background-size: 200% 100%;
        animation: loading 1.5s infinite;
        width: 45px;
        height: 45px;
        border-radius: 12px;
    }
    
    .skeleton-title { width: 120px; height: 16px; }
    .skeleton-subtitle { width: 80px; }
    .skeleton-col { height: 14px; }
    .skeleton-btn { 
        width: 36px; height: 36px; border-radius: 10px;
        background: rgba(255,255,255,0.05);
    }
    
    @@keyframes loading {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }
</style>

@code {
    private List<UserSessionDto> _activeUsers = new();
    private bool _isLoading = true;
    private PeriodicTimer? _timer;

    // Model DTO map với dữ liệu API Active Sessions
    public class UserSessionDto
    {
        public int Id { get; set; }
        public string UserType { get; set; } = string.Empty;
        public string Identifier { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public string Avatar { get; set; } = string.Empty;
        public string IpAddress { get; set; } = string.Empty;
        public string UserAgent { get; set; } = string.Empty;
        public DateTime LastActive { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        // 1. Tải danh sách lần đầu
        await FetchActiveSessionsAsync();
        _isLoading = false;

        // 2. Bắt đầu bộ đếm tự động lấy dữ liệu (Auto-Refresh Background Worker)
        StartPolling();
    }

    private void StartPolling()
    {
        // Thiết lập bộ đếm cực nhẹ thay vì dùng System.Timers.Timer cũ dễ lỗi
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(15));
        
        // Chạy bất đồng bộ ngầm mà không chặn luồng chính (Fire-and-forget)
        _ = PollDataAsync();
    }

    private async Task PollDataAsync()
    {
        try
        {
            // Vòng lặp sẽ tự động chờ 15 giây, tiếp tục chừng nào chưa bị Dispose
            while (await _timer!.WaitForNextTickAsync())
            {
                await FetchActiveSessionsAsync();
                
                // MẸO: Tránh nháy màn hình (Flickering)
                // Cập nhật ngầm dữ liệu mới vào list, sau đó gọi StateHasChanged()
                // Virtual DOM của Blazor sẽ so sánh thông minh và chỉ render đúng HTML của ông khách mới/cũ bị đổi ID.
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Ngoại lệ này xảy ra hoàn toàn bình thường khi Timer bị hủy (Dispose)
        }
    }

    private async Task FetchActiveSessionsAsync()
    {
        try
        {
            // Bạn hỏi tại sao tắt tab đi nó vẫn online? Vì tôi đang set 300s (5 phút) ở đây.
            // Giải pháp: Khi người dùng tắt tab, Ping ngầm 15s/lần bị ngừng lại.
            // Chỉ cần set lại ngưỡng 30 giây: Ai không có tín hiệu ping trong 30s lập tức bị xóa!
            var sessions = Tracker.GetActiveSessions(5) 
            
            // Map từ Services.UserSessionDto sang local Dto
            _activeUsers = sessions.Select(s => new UserSessionDto
            {
                Id = s.Id,
                UserType = s.UserType,
                Identifier = s.Identifier,
                DisplayName = s.DisplayName,
                Avatar = s.Avatar,
                IpAddress = s.IpAddress,
                UserAgent = s.UserAgent,
                LastActive = s.LastActive
            }).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Error Load Sessions]: {ex.Message}");
        }
    }

    // Tiện ích: Hiển thị 8 ký tự đầu, 4 ký tự cuối (VKT-8A2F...7D1E)
    private string TruncateId(string id)
    {
        if (string.IsNullOrEmpty(id) || id.Length <= 12) return id;
        return $"{id.Substring(0, 8)}...{id.Substring(id.Length - 4)}";
    }

    // Tiện ích: Cắt bớt UserAgent tránh vỡ khung Table
    private string TruncateUserAgent(string ua)
    {
        if (string.IsNullOrEmpty(ua)) return "Unknown Device";
        if (ua.Length <= 45) return ua;
        return ua.Substring(0, 45) + "...";
    }

    public void Dispose()
    {
        // GIẢI PHÁP 1 CHO RÒ RỈ BỘ NHỚ: 
        // Khi Admin bấm sang trang khác, Component này bị Hủy (Dispose).
        // Phải Dispose Timer ở đây, hàm WaitForNextTickAsync() sẽ quăng Exception và ngắt luôn vòng lặp While.
        _timer?.Dispose();
    }
}
