@page "/tours/new"
@page "/tours/edit/{Id:int}"
@using VinhKhanhTour.Shared.Models
@using VinhKhanhTour.CMS.Services
@using System.Text.Json
@implements IDisposable
@inject IJSRuntime JS
@inject TourService TourService
@inject PoiService PoiService
@inject NavigationManager NavManager

<PageTitle>@(IsEdit ? "Sửa Tour" : "Thêm Tour Mới") - VinhKhanh Tour</PageTitle>

<div class="dashboard-container page-transition">
    <div class="header-section">
        <h1 class="header-title">@(IsEdit ? "✏️ Sửa Tour" : "➕ Thêm Tour Mới")</h1>
        <button class="btn btn-secondary" @onclick='() => NavManager.NavigateTo("/tours")'>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Quay lại
        </button>
    </div>

    <div class="form-container">
        <EditForm Model="@dto" OnValidSubmit="SaveTour">
            <DataAnnotationsValidator />

            @* ===== THÔNG TIN TOUR ===== *@
            <div class="form-group">
                <label class="form-label">Tên Tour</label>
                <InputText @bind-Value="dto.TourName" class="form-control" placeholder="Nhập tên tour du lịch..." required />
            </div>
            <div class="form-group">
                <label class="form-label">Mô tả</label>
                <InputTextArea @bind-Value="dto.Description" class="form-control" rows="3" placeholder="Mô tả chi tiết về tour này..." />
            </div>
            <div class="form-group">
                <label class="form-label">Link Hình ảnh</label>
                <InputText @bind-Value="dto.ImageUrl" class="form-control" placeholder="https://... hoặc tên file ảnh" />
            </div>

            @* ===== BẢN ĐỒ LỘ TRÌNH ===== *@
            <div class="form-group" style="margin-top: 2rem;">
                <h3 style="margin: 0 0 0.5rem; color: var(--text-primary); font-size: 1.1rem;">🗺️ Lộ trình trên bản đồ</h3>
                <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1rem;">
                    Click lần 1 để đặt <span style="color:#22c55e;font-weight:bold;">điểm A (bắt đầu)</span>,
                    click lần 2 để đặt <span style="color:#ef4444;font-weight:bold;">điểm B (kết thúc)</span>.
                    Hệ thống sẽ tự vẽ đường đi và tìm các điểm dừng.
                </p>

                @* Map container *@
                <div id="tourMapContainer" style="width:100%;height:420px;border-radius:12px;overflow:hidden;border:2px solid rgba(245,158,11,0.3);"></div>

                @* Thông tin Start / End *@
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1rem;">
                    <div class="route-info-card" style="border-left:3px solid #22c55e;">
                        <div style="font-size:0.8rem;color:var(--text-secondary);margin-bottom:0.3rem;">📍 Điểm bắt đầu (A)</div>
                        @if (startLat != 0)
                        {
                            <div style="font-size:0.9rem;color:var(--text-primary);font-weight:500;">@startLat.ToString("F6"), @startLng.ToString("F6")</div>
                        }
                        else
                        {
                            <div style="font-size:0.85rem;color:var(--text-secondary);font-style:italic;">Chưa chọn — click trên map</div>
                        }
                    </div>
                    <div class="route-info-card" style="border-left:3px solid #ef4444;">
                        <div style="font-size:0.8rem;color:var(--text-secondary);margin-bottom:0.3rem;">🏁 Điểm kết thúc (B)</div>
                        @if (endLat != 0)
                        {
                            <div style="font-size:0.9rem;color:var(--text-primary);font-weight:500;">@endLat.ToString("F6"), @endLng.ToString("F6")</div>
                        }
                        else
                        {
                            <div style="font-size:0.85rem;color:var(--text-secondary);font-style:italic;">Chưa chọn — click trên map</div>
                        }
                    </div>
                </div>

                @* Quãng đường *@
                @if (dto.TotalDistance > 0)
                {
                    <div style="margin-top:0.8rem;padding:0.8rem 1rem;background:rgba(245,158,11,0.1);border-radius:8px;display:flex;align-items:center;gap:0.5rem;">
                        <span style="font-size:1.2rem;">📏</span>
                        <span style="color:var(--text-primary);font-weight:600;">Quãng đường: @dto.TotalDistance km</span>
                    </div>
                }
            </div>

            @* ===== DANH SÁCH ĐIỂM DỪNG TỰ DETECT ===== *@
            @if (isCalculating)
            {
                <div style="margin-top:1.5rem;padding:2rem;text-align:center;color:var(--text-secondary);">
                    <div class="loading-spinner">
                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
                    </div>
                    <p class="loading-pulse" style="margin-top:0.5rem;">Đang tìm điểm dừng trên lộ trình...</p>
                </div>
            }
            else if (dto.Stops.Any())
            {
                <div style="margin-top:2rem;">
                    <h3 style="margin:0 0 1rem;color:var(--text-primary);font-size:1.1rem;">
                        📌 Điểm dừng trên lộ trình
                        <span style="font-size:0.85rem;color:var(--text-secondary);font-weight:400;margin-left:0.5rem;">
                            (@dto.Stops.Count điểm)
                        </span>
                    </h3>

                    <div class="stops-list">
                        @foreach (var stop in dto.Stops.OrderBy(s => s.OrderIndex).ToList())
                        {
                            <div class="stop-item" @key="stop.PoiId">
                                <div class="stop-index">@stop.OrderIndex</div>
                                <div class="stop-info">
                                    <div class="stop-name">@stop.PoiName</div>
                                    <div class="stop-coords">@stop.Latitude.ToString("F6"), @stop.Longitude.ToString("F6")</div>
                                </div>
                                <button type="button" class="stop-remove-btn" title="Xóa điểm dừng này" @onclick="() => RemoveStop(stop)">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
            else if (startLat != 0 && endLat != 0)
            {
                <div style="margin-top:1.5rem;padding:1.5rem;text-align:center;background:rgba(245,158,11,0.05);border-radius:10px;border:1px dashed rgba(245,158,11,0.3);">
                    <span style="font-size:1.5rem;">🔍</span>
                    <p style="color:var(--text-secondary);margin:0.5rem 0 0;">Không tìm thấy điểm dừng nào trên lộ trình này.</p>
                </div>
            }

            @* ===== BUTTONS ===== *@
            <div style="margin-top: 2rem; display: flex; justify-content: flex-end; gap: 1rem;">
                <button type="button" class="btn btn-secondary" @onclick='() => NavManager.NavigateTo("/tours")'>Hủy</button>
                <button type="submit" class="btn btn-primary" disabled="@(string.IsNullOrWhiteSpace(dto.TourName))">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                    @(IsEdit ? "Lưu thay đổi" : "Tạo Tour")
                </button>
            </div>
        </EditForm>
    </div>
</div>

<style>
    .route-info-card {
        padding: 0.8rem 1rem;
        background: rgba(255,255,255,0.03);
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.06);
    }

    .stops-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .stop-item {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding: 0.8rem 1rem;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 10px;
        transition: all 0.2s ease;
    }

    .stop-item:hover {
        background: rgba(245,158,11,0.08);
        border-color: rgba(245,158,11,0.2);
    }

    .stop-index {
        width: 30px;
        height: 30px;
        background: var(--primary-color, #f59e0b);
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .stop-info {
        flex: 1;
        min-width: 0;
    }

    .stop-name {
        font-weight: 600;
        color: var(--text-primary);
        font-size: 0.95rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .stop-coords {
        font-size: 0.78rem;
        color: var(--text-secondary);
        margin-top: 2px;
    }

    .stop-remove-btn {
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.2);
        color: #ef4444;
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        flex-shrink: 0;
    }

    .stop-remove-btn:hover {
        background: rgba(239,68,68,0.2);
        border-color: rgba(239,68,68,0.4);
    }
</style>

@code {
    [Parameter]
    public int? Id { get; set; }

    private bool IsEdit => Id.HasValue;
    private TourCreateUpdateDto dto = new();
    private DotNetObjectReference<TourForm>? dotNetRef;

    private double startLat, startLng, endLat, endLng;
    private bool isCalculating = false;
    private List<Poi> allPois = new();

    // Bán kính detect POI (50 mét)
    private const double POI_DETECT_RADIUS_METERS = 50;

    public void Dispose()
    {
        dotNetRef?.Dispose();
        _ = JS.InvokeVoidAsync("tourMapInterop.dispose");
    }

    protected override async Task OnInitializedAsync()
    {
        dotNetRef = DotNetObjectReference.Create(this);

        // Load tất cả POI từ DB
        allPois = await PoiService.GetPoisAsync();

        if (IsEdit && Id.HasValue)
        {
            var existing = await TourService.GetTourByIdAsync(Id.Value);
            if (existing != null)
            {
                dto = new TourCreateUpdateDto
                {
                    TourName = existing.TourName,
                    Description = existing.Description,
                    ImageUrl = existing.ImageUrl,
                    StartPoint = existing.StartPoint,
                    EndPoint = existing.EndPoint,
                    TotalDistance = existing.TotalDistance,
                    Stops = existing.Stops
                };

                // Parse start/end coordinates from stored string
                ParseStoredCoordinates(existing.StartPoint, out startLat, out startLng);
                ParseStoredCoordinates(existing.EndPoint, out endLat, out endLng);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(150);
            await JS.InvokeVoidAsync("tourMapInterop.initTourMap",
                "tourMapContainer", dotNetRef, startLat, startLng, endLat, endLng);
        }
    }

    // ===== JS CALLBACKS =====

    [JSInvokable]
    public void UpdateStartPoint(double lat, double lng)
    {
        startLat = Math.Round(lat, 6);
        startLng = Math.Round(lng, 6);
        dto.StartPoint = $"{startLat}, {startLng}";
        StateHasChanged();
    }

    [JSInvokable]
    public void UpdateEndPoint(double lat, double lng)
    {
        endLat = Math.Round(lat, 6);
        endLng = Math.Round(lng, 6);
        dto.EndPoint = $"{endLat}, {endLng}";
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnRouteCalculated(string routePointsJson, double distanceKm)
    {
        isCalculating = true;
        StateHasChanged();

        try
        {
            dto.TotalDistance = distanceKm;

            // Parse route points
            var routePoints = JsonSerializer.Deserialize<List<RoutePoint>>(routePointsJson,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (routePoints == null || routePoints.Count == 0) return;

            // Tìm POI gần route
            var matchedStops = new List<TourStopDto>();

            foreach (var poi in allPois)
            {
                double minDistance = double.MaxValue;

                // So sánh POI với từng điểm trên route
                // Chỉ sample 1 phần route để tránh lag (lấy mỗi 3 điểm)
                for (int i = 0; i < routePoints.Count; i += 3)
                {
                    double dist = HaversineDistance(poi.Latitude, poi.Longitude,
                        routePoints[i].Lat, routePoints[i].Lng);

                    if (dist < minDistance) minDistance = dist;
                    if (dist <= POI_DETECT_RADIUS_METERS) break; // Đã match, không cần kiểm tra thêm
                }

                if (minDistance <= POI_DETECT_RADIUS_METERS)
                {
                    matchedStops.Add(new TourStopDto
                    {
                        PoiId = poi.Id,
                        PoiName = poi.Name,
                        Description = poi.Description,
                        Latitude = poi.Latitude,
                        Longitude = poi.Longitude,
                        OrderIndex = 0 // sẽ gán sau
                    });
                }
            }

            // Sắp xếp POI theo thứ tự trên route
            matchedStops = SortStopsByRouteOrder(matchedStops, routePoints);

            // Gán OrderIndex
            for (int i = 0; i < matchedStops.Count; i++)
            {
                matchedStops[i].OrderIndex = i + 1;
            }

            dto.Stops = matchedStops;

            // Hiển thị POI markers trên map
            var poisForMap = matchedStops.Select(s => new { poiName = s.PoiName, description = s.Description, latitude = s.Latitude, longitude = s.Longitude }).ToList();
            await JS.InvokeVoidAsync("tourMapInterop.showPoiMarkers", JsonSerializer.Serialize(poisForMap));
        }
        finally
        {
            isCalculating = false;
            StateHasChanged();
        }
    }

    // ===== HELPERS =====

    private void RemoveStop(TourStopDto stop)
    {
        dto.Stops.Remove(stop);
        // Re-index
        var ordered = dto.Stops.OrderBy(s => s.OrderIndex).ToList();
        for (int i = 0; i < ordered.Count; i++)
        {
            ordered[i].OrderIndex = i + 1;
        }
        dto.Stops = ordered;

        // Update map markers
        var poisForMap = dto.Stops.Select(s => new { poiName = s.PoiName, description = s.Description, latitude = s.Latitude, longitude = s.Longitude }).ToList();
        _ = JS.InvokeVoidAsync("tourMapInterop.showPoiMarkers", JsonSerializer.Serialize(poisForMap));

        StateHasChanged();
    }

    /// <summary>
    /// Sắp xếp Stops theo thứ tự xuất hiện trên route
    /// (tìm điểm route gần nhất với mỗi POI, rồi sort theo index của điểm đó)
    /// </summary>
    private List<TourStopDto> SortStopsByRouteOrder(List<TourStopDto> stops, List<RoutePoint> routePoints)
    {
        var stopWithIndex = stops.Select(stop =>
        {
            int closestIndex = 0;
            double closestDist = double.MaxValue;

            for (int i = 0; i < routePoints.Count; i += 3)
            {
                double dist = HaversineDistance(stop.Latitude, stop.Longitude,
                    routePoints[i].Lat, routePoints[i].Lng);
                if (dist < closestDist)
                {
                    closestDist = dist;
                    closestIndex = i;
                }
            }

            return new { Stop = stop, RouteIndex = closestIndex };
        });

        return stopWithIndex.OrderBy(x => x.RouteIndex).Select(x => x.Stop).ToList();
    }

    /// <summary>
    /// Tính khoảng cách Haversine (mét) giữa 2 tọa độ GPS
    /// </summary>
    private static double HaversineDistance(double lat1, double lon1, double lat2, double lon2)
    {
        const double R = 6371000; // bán kính Trái Đất (mét)
        double dLat = (lat2 - lat1) * Math.PI / 180;
        double dLon = (lon2 - lon1) * Math.PI / 180;
        double a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2)
                 + Math.Cos(lat1 * Math.PI / 180) * Math.Cos(lat2 * Math.PI / 180)
                 * Math.Sin(dLon / 2) * Math.Sin(dLon / 2);
        double c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
        return R * c;
    }

    private static void ParseStoredCoordinates(string coordString, out double lat, out double lng)
    {
        lat = 0; lng = 0;
        if (string.IsNullOrWhiteSpace(coordString)) return;

        var parts = coordString.Split(',');
        if (parts.Length == 2)
        {
            double.TryParse(parts[0].Trim(), System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out lat);
            double.TryParse(parts[1].Trim(), System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out lng);
        }
    }

    private async Task SaveTour()
    {
        // Set start/end point text
        if (startLat != 0) dto.StartPoint = $"{startLat}, {startLng}";
        if (endLat != 0) dto.EndPoint = $"{endLat}, {endLng}";

        if (IsEdit && Id.HasValue)
        {
            await TourService.UpdateTourAsync(Id.Value, dto);
        }
        else
        {
            await TourService.CreateTourAsync(dto);
        }
        NavManager.NavigateTo("/tours");
    }

    // DTO nội bộ cho route points từ JS
    private class RoutePoint
    {
        public double Lat { get; set; }
        public double Lng { get; set; }
    }
}
