@page "/register"
@attribute [AllowAnonymous]
@layout VinhKhanhTour.CMS.Components.Layout.EmptyLayout
@using VinhKhanhTour.Shared.Models
@using VinhKhanhTour.CMS.Data
@using Microsoft.EntityFrameworkCore
@inject NavigationManager NavigationManager
@inject IDbContextFactory<CmsDbContext> DbFactory
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

<PageTitle>Đăng ký Chủ Quán - VinhKhanhTour</PageTitle>

<div class="register-container">
    <div class="register-card">
        @if (IsSuccess)
        {
            <div class="success-screen">
                <div class="success-icon">🎉</div>
                <h2>Đăng ký thành công!</h2>
                <p>Chào mừng bạn đến với VinhKhanh Tour</p>
                <div class="success-details">
                    <div class="detail-row">
                        <span class="detail-label">SĐT (Username)</span>
                        <span class="detail-value">@RequestData.PhoneNumber</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Quán</span>
                        <span class="detail-value">@RequestData.PoiName</span>
                    </div>
                </div>
                <a href="/login" class="btn-login">Đến trang Đăng Nhập →</a>
            </div>
        }
        else
        {
            <!-- STEPPER -->
            <div class="stepper">
                <div class="step-item @(currentStep >= 1 ? "active" : "") @(currentStep > 1 ? "completed" : "")">
                    <div class="step-circle">@(currentStep > 1 ? "✓" : "1")</div>
                    <span class="step-label">Khách hàng</span>
                </div>
                <div class="step-line @(currentStep >= 2 ? "active" : "")"></div>
                <div class="step-item @(currentStep >= 2 ? "active" : "") @(currentStep > 2 ? "completed" : "")">
                    <div class="step-circle">@(currentStep > 2 ? "✓" : "2")</div>
                    <span class="step-label">Quán</span>
                </div>
                <div class="step-line @(currentStep >= 3 ? "active" : "")"></div>
                <div class="step-item @(currentStep >= 3 ? "active" : "")">
                    <div class="step-circle">3</div>
                    <span class="step-label">Thanh toán</span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="error-box">🚨 @ErrorMessage</div>
            }

            <EditForm Model="@RequestData" OnValidSubmit="HandleRegistration">
                <DataAnnotationsValidator />

                <!-- ====== STEP 1: Thông tin khách hàng ====== -->
                @if (currentStep == 1)
                {
                    <div class="step-panel" style="animation: slideIn 0.35s ease">
                        <h3 class="step-title">👤 Thông tin khách hàng</h3>

                        <div class="form-group">
                            <label>Họ và Tên chủ quán <span class="req">*</span></label>
                            <InputText @bind-Value="RequestData.FullName" class="form-control" placeholder="VD: Nguyễn Văn A" />
                            <ValidationMessage For="@(() => RequestData.FullName)" class="field-error" />
                        </div>

                        <div class="form-group">
                            <label>Số điện thoại <span class="req">*</span> <small class="hint">(Dùng làm tên đăng nhập)</small></label>
                            <InputText @bind-Value="RequestData.PhoneNumber" class="form-control" placeholder="VD: 0901234567" />
                            <ValidationMessage For="@(() => RequestData.PhoneNumber)" class="field-error" />
                        </div>

                        <div class="form-group">
                            <label>Email <small class="hint">(Không bắt buộc)</small></label>
                            <InputText @bind-Value="RequestData.Email" class="form-control" placeholder="example@gmail.com" />
                            <ValidationMessage For="@(() => RequestData.Email)" class="field-error" />
                        </div>

                        <div class="form-group">
                            <label>Mật khẩu <span class="req">*</span></label>
                            <InputText @bind-Value="RequestData.Password" type="password" class="form-control" placeholder="Tối thiểu 3 ký tự" />
                            <ValidationMessage For="@(() => RequestData.Password)" class="field-error" />
                        </div>

                        <div class="form-group">
                            <label>Xác nhận mật khẩu <span class="req">*</span></label>
                            <InputText @bind-Value="RequestData.ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu" />
                            <ValidationMessage For="@(() => RequestData.ConfirmPassword)" class="field-error" />
                        </div>

                        <button type="button" class="btn-next" @onclick="GoToStep2">
                            Tiếp tục: Thông tin quán →
                        </button>
                    </div>
                }

                <!-- ====== STEP 2: Thông tin quán ====== -->
                @if (currentStep == 2)
                {
                    <!-- Summary Step 1 -->
                    <div class="summary-card" style="animation: fadeIn 0.3s ease">
                        <div class="summary-header">
                            <span>✅ Thông tin khách hàng</span>
                            <button type="button" class="btn-edit" @onclick="() => currentStep = 1">Sửa</button>
                        </div>
                        <div class="summary-body">
                            <span>@RequestData.FullName</span> · <span>@RequestData.PhoneNumber</span>
                        </div>
                    </div>

                    <div class="step-panel" style="animation: slideIn 0.35s ease">
                        <h3 class="step-title">🏪 Thông tin quán</h3>

                        <div class="form-group">
                            <label>Tên địa điểm / Quán (POI) <span class="req">*</span></label>
                            <InputText @bind-Value="RequestData.PoiName" class="form-control" placeholder="VD: Ốc Oanh" />
                            <ValidationMessage For="@(() => RequestData.PoiName)" class="field-error" />
                        </div>

                        <div class="form-group">
                            <label>Địa chỉ <span class="req">*</span></label>
                            <InputText @bind-Value="RequestData.Address" class="form-control" placeholder="VD: 15 Vĩnh Khánh, Q4" />
                            <ValidationMessage For="@(() => RequestData.Address)" class="field-error" />
                        </div>

                        <div class="form-group">
                            <label>Loại hình kinh doanh <span class="req">*</span></label>
                            <InputSelect @bind-Value="RequestData.BusinessType" class="form-control">
                                <option value="">— Chọn loại hình —</option>
                                <option value="seafood">🐚 Ốc & Hải sản</option>
                                <option value="bbq">🍖 Lẩu & Nướng</option>
                                <option value="noodle">🍜 Bún, Phở & Hủ Tiếu</option>
                                <option value="rice">🍚 Cơm & Đồ ăn gia đình</option>
                                <option value="dessert">🧁 Tráng miệng & Đồ uống</option>
                                <option value="street_food">🥙 Ăn vặt & Đường phố</option>
                                <option value="other">📍 Khác</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => RequestData.BusinessType)" class="field-error" />
                        </div>

                        <div class="btn-row">
                            <button type="button" class="btn-back" @onclick="() => currentStep = 1">← Quay lại</button>
                            <button type="button" class="btn-next" @onclick="GoToStep3">Tiếp tục: Thanh toán →</button>
                        </div>
                    </div>
                }

                <!-- ====== STEP 3: Thanh toán ====== -->
                @if (currentStep == 3)
                {
                    <!-- Summary Step 1 + 2 -->
                    <div class="summary-card" style="animation: fadeIn 0.3s ease">
                        <div class="summary-header">
                            <span>✅ Khách hàng</span>
                            <button type="button" class="btn-edit" @onclick="() => currentStep = 1">Sửa</button>
                        </div>
                        <div class="summary-body">
                            <span>@RequestData.FullName</span> · <span>@RequestData.PhoneNumber</span>
                        </div>
                    </div>
                    <div class="summary-card" style="animation: fadeIn 0.3s ease 0.1s both">
                        <div class="summary-header">
                            <span>✅ Quán</span>
                            <button type="button" class="btn-edit" @onclick="() => currentStep = 2">Sửa</button>
                        </div>
                        <div class="summary-body">
                            <span>@RequestData.PoiName</span> · <span>@RequestData.Address</span>
                        </div>
                    </div>

                    <div class="step-panel" style="animation: slideIn 0.35s ease">
                        <h3 class="step-title">💳 Phương thức thanh toán</h3>

                        <div class="price-banner">
                            <span class="price-label">Phí khởi tạo</span>
                            <span class="price-amount">500,000 <small>VND</small></span>
                            <span class="price-note">Thanh toán một lần · Sử dụng vĩnh viễn</span>
                        </div>

                        <div class="payment-options">
                            <div class="pay-card @(RequestData.PaymentMethod == "bank_transfer" ? "selected" : "")"
                                 @onclick='() => RequestData.PaymentMethod = "bank_transfer"'>
                                <span class="pay-icon">🏦</span>
                                <span class="pay-name">Chuyển khoản ngân hàng</span>
                            </div>
                            <div class="pay-card @(RequestData.PaymentMethod == "credit_card" ? "selected" : "")"
                                 @onclick='() => RequestData.PaymentMethod = "credit_card"'>
                                <span class="pay-icon">💳</span>
                                <span class="pay-name">Thẻ tín dụng</span>
                            </div>
                            <div class="pay-card @(RequestData.PaymentMethod == "e_wallet" ? "selected" : "")"
                                 @onclick='() => RequestData.PaymentMethod = "e_wallet"'>
                                <span class="pay-icon">📱</span>
                                <span class="pay-name">Ví điện tử</span>
                            </div>
                        </div>

                        <div class="demo-notice">
                            🧪 <strong>Bản Demo</strong> — Thanh toán sẽ được giả lập tự động hoàn thành.
                        </div>

                        <div class="btn-row">
                            <button type="button" class="btn-back" @onclick="() => currentStep = 2">← Quay lại</button>
                            <button type="submit" class="btn-submit" disabled="@IsSubmitting">
                                @if (IsSubmitting)
                                {
                                    <span class="btn-spinner"></span> <span>Đang xử lý...</span>
                                }
                                else
                                {
                                    <span>Hoàn tất đăng ký & Thanh toán</span>
                                }
                            </button>
                        </div>
                    </div>
                }
            </EditForm>
        }

        <div class="login-link">
            Đã có tài khoản? <a href="/login">Đăng nhập ngay</a>
        </div>
    </div>
</div>

<style>
    *, *::before, *::after { box-sizing: border-box; }
    body, html { margin: 0; padding: 0; min-height: 100vh; background: #0f172a; color: #fff; font-family: 'Inter', system-ui, -apple-system, sans-serif; }

    .register-container {
        min-height: 100vh; display: flex; align-items: center; justify-content: center;
        padding: 24px 16px; position: relative;
        background: url('/images/vinh_khanh_food_street_banner.jpg') no-repeat center center;
        background-size: cover; background-attachment: fixed;
    }
    .register-container::before {
        content: ""; position: fixed; inset: 0;
        background: linear-gradient(180deg, rgba(15,23,42,0.85) 0%, rgba(15,23,42,0.92) 50%, rgba(15,23,42,0.88) 100%);
        z-index: 1;
    }

    .register-card {
        position: relative; z-index: 2;
        background: rgba(30, 41, 59, 0.6); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255,255,255,0.08); border-radius: 1.25rem;
        padding: 36px 28px; width: 100%; max-width: 480px;
        box-shadow: 0 12px 48px rgba(0,0,0,0.5);
        max-height: 92vh; overflow-y: auto;
    }
    .register-card::-webkit-scrollbar { width: 4px; }
    .register-card::-webkit-scrollbar-track { background: transparent; }
    .register-card::-webkit-scrollbar-thumb { background: rgba(16,185,129,0.3); border-radius: 4px; }

    /* ===== STEPPER ===== */
    .stepper { display: flex; align-items: center; justify-content: center; margin-bottom: 28px; gap: 0; }
    .step-item { display: flex; flex-direction: column; align-items: center; gap: 6px; position: relative; }
    .step-circle {
        width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
        font-size: 0.85rem; font-weight: 700;
        background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.35);
        border: 2px solid rgba(255,255,255,0.12);
        transition: all 0.3s ease;
    }
    .step-item.active .step-circle {
        background: linear-gradient(135deg, #10b981, #059669);
        color: #fff; border-color: #10b981;
        box-shadow: 0 0 16px rgba(16,185,129,0.4);
    }
    .step-item.completed .step-circle {
        background: #10b981; border-color: #10b981; color: #fff;
    }
    .step-label { font-size: 0.7rem; color: rgba(255,255,255,0.35); font-weight: 500; }
    .step-item.active .step-label { color: #10b981; }
    .step-item.completed .step-label { color: #10b981; }
    .step-line {
        width: 48px; height: 2px; background: rgba(255,255,255,0.08);
        margin: 0 6px; margin-bottom: 20px; transition: background 0.3s;
    }
    .step-line.active { background: linear-gradient(90deg, #10b981, #3b82f6); }

    /* ===== FORM ===== */
    .step-panel { }
    .step-title { font-family: 'Space Grotesk', sans-serif; color: #10b981; font-size: 1.15rem; font-weight: 700; margin: 0 0 20px; }

    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 600; margin-bottom: 6px; color: #e2e8f0; font-size: 0.9rem; }
    .req { color: #f87171; }
    .hint { color: rgba(255,255,255,0.4); font-weight: 400; }

    .form-control {
        width: 100%; padding: 12px 14px; border: 1px solid rgba(255,255,255,0.1);
        border-radius: 0.75rem; background: rgba(15,23,42,0.5); color: #fff;
        font-size: 0.95rem; transition: all 0.3s; outline: none;
        font-family: 'Inter', sans-serif;
    }
    .form-control:focus {
        border-color: #10b981; box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
        background: rgba(15,23,42,0.7);
    }
    .form-control::placeholder { color: rgba(255,255,255,0.25); }
    select.form-control { cursor: pointer; appearance: none; }

    .field-error { color: #f87171; font-size: 0.82rem; margin-top: 4px; display: block; }
    .error-box {
        background: rgba(239,68,68,0.1); color: #f87171; border: 1px solid rgba(239,68,68,0.25);
        border-radius: 0.75rem; padding: 12px 16px; margin-bottom: 16px; font-size: 0.9rem;
    }

    /* ===== BUTTONS ===== */
    .btn-next {
        width: 100%; padding: 14px; border: none; border-radius: 0.85rem; cursor: pointer;
        background: linear-gradient(135deg, #10b981, #059669); color: #fff;
        font-size: 1rem; font-weight: 700; transition: all 0.3s;
        margin-top: 8px; box-shadow: 0 4px 14px rgba(16,185,129,0.3);
    }
    .btn-next:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(16,185,129,0.4); }

    .btn-back {
        padding: 12px 20px; border: 1px solid rgba(255,255,255,0.15); border-radius: 0.85rem;
        background: transparent; color: rgba(255,255,255,0.7); font-size: 0.95rem;
        cursor: pointer; font-weight: 500; transition: all 0.3s;
    }
    .btn-back:hover { border-color: rgba(255,255,255,0.3); color: #fff; }

    .btn-row { display: flex; gap: 12px; margin-top: 12px; }
    .btn-row .btn-next { flex: 1; }

    .btn-submit {
        flex: 1; padding: 14px; border: none; border-radius: 0.85rem; cursor: pointer;
        background: linear-gradient(135deg, #10b981, #059669); color: #fff;
        font-size: 1rem; font-weight: 700; transition: all 0.3s;
        display: flex; align-items: center; justify-content: center; gap: 8px;
        box-shadow: 0 4px 14px rgba(16,185,129,0.3);
    }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(16,185,129,0.4); }
    .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    .btn-spinner {
        width: 18px; height: 18px; border: 3px solid rgba(255,255,255,0.3);
        border-top-color: #fff; border-radius: 50%; display: inline-block;
        animation: spin 0.7s linear infinite;
    }

    /* ===== SUMMARY CARD ===== */
    .summary-card {
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
        border-radius: 0.75rem; padding: 12px 16px; margin-bottom: 12px;
    }
    .summary-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
    .summary-header span { font-size: 0.82rem; color: #10b981; font-weight: 600; }
    .btn-edit {
        background: none; border: none; color: #3b82f6; font-size: 0.78rem;
        cursor: pointer; text-decoration: underline; padding: 0;
    }
    .summary-body { color: rgba(255,255,255,0.6); font-size: 0.85rem; }

    /* ===== PAYMENT ===== */
    .price-banner {
        background: rgba(16,185,129,0.06); border: 1px dashed rgba(16,185,129,0.25);
        border-radius: 1rem; padding: 20px; text-align: center; margin-bottom: 20px;
    }
    .price-label { display: block; color: rgba(255,255,255,0.5); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
    .price-amount { display: block; font-family: 'Space Grotesk', sans-serif; font-size: 2.2rem; font-weight: 700; color: #f59e0b; }
    .price-amount small { font-size: 0.9rem; color: rgba(255,255,255,0.5); }
    .price-note { display: block; color: rgba(255,255,255,0.4); font-size: 0.8rem; margin-top: 4px; }

    .payment-options { display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; }
    .pay-card {
        display: flex; align-items: center; gap: 14px; padding: 14px 16px;
        border: 1px solid rgba(255,255,255,0.08); border-radius: 0.75rem;
        background: rgba(255,255,255,0.03); cursor: pointer; transition: all 0.3s;
    }
    .pay-card:hover { border-color: rgba(16,185,129,0.3); background: rgba(16,185,129,0.05); }
    .pay-card.selected {
        border-color: #10b981; background: rgba(16,185,129,0.1);
        box-shadow: 0 0 0 2px rgba(16,185,129,0.15);
    }
    .pay-icon { font-size: 1.4rem; }
    .pay-name { color: #e2e8f0; font-weight: 500; font-size: 0.95rem; }

    .demo-notice {
        background: rgba(245,158,11,0.08); border: 1px dashed rgba(245,158,11,0.25);
        border-radius: 0.75rem; padding: 10px 14px; font-size: 0.82rem;
        color: rgba(245,158,11,0.8); margin-bottom: 16px;
    }

    /* ===== SUCCESS ===== */
    .success-screen { text-align: center; padding: 20px 0; }
    .success-icon { font-size: 56px; margin-bottom: 12px; animation: bounce 0.6s ease; }
    .success-screen h2 { font-family: 'Space Grotesk', sans-serif; color: #10b981; font-size: 1.5rem; margin: 0 0 6px; -webkit-text-fill-color: #10b981; }
    .success-screen > p { color: rgba(255,255,255,0.6); margin: 0 0 20px; }
    .success-details {
        background: rgba(255,255,255,0.04); border-radius: 0.75rem; padding: 16px; margin-bottom: 20px;
    }
    .detail-row { display: flex; justify-content: space-between; padding: 6px 0; }
    .detail-label { color: rgba(255,255,255,0.5); font-size: 0.85rem; }
    .detail-value { color: #10b981; font-weight: 600; font-size: 0.9rem; }
    .btn-login {
        display: inline-block; padding: 14px 32px; border-radius: 0.85rem;
        background: linear-gradient(135deg, #10b981, #059669); color: #fff;
        font-weight: 700; text-decoration: none; font-size: 1rem;
        box-shadow: 0 4px 14px rgba(16,185,129,0.3);
    }

    .login-link { text-align: center; margin-top: 20px; color: rgba(255,255,255,0.4); font-size: 0.85rem; }
    .login-link a { color: #10b981; text-decoration: underline; }

    /* ===== ANIMATIONS ===== */
    @@keyframes slideIn { from { opacity: 0; transform: translateX(30px); } to { opacity: 1; transform: translateX(0); } }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes spin { to { transform: rotate(360deg); } }
    @@keyframes bounce { 0% { transform: scale(0); } 60% { transform: scale(1.15); } 100% { transform: scale(1); } }

    /* ===== MOBILE ===== */
    @@media (max-width: 500px) {
        .register-card { padding: 24px 18px; border-radius: 1rem; }
        .stepper { gap: 0; }
        .step-line { width: 32px; }
        .step-label { font-size: 0.6rem; }
        .price-amount { font-size: 1.8rem; }
    }
</style>

@code {
    private MerchantRegistrationRequest RequestData { get; set; } = new MerchantRegistrationRequest();
    private bool IsSubmitting = false;
    private bool IsSuccess = false;
    private string? ErrorMessage { get; set; }
    private int currentStep = 1;

    private void GoToStep2()
    {
        ErrorMessage = null;

        // Validate step 1 fields
        if (string.IsNullOrWhiteSpace(RequestData.FullName))
        { ErrorMessage = "Vui lòng nhập Họ và Tên."; return; }

        if (string.IsNullOrWhiteSpace(RequestData.PhoneNumber))
        { ErrorMessage = "Vui lòng nhập Số điện thoại."; return; }

        var phoneRegex = new System.Text.RegularExpressions.Regex(@"^(03|05|07|08|09)+([0-9]{8})$");
        if (!phoneRegex.IsMatch(RequestData.PhoneNumber))
        { ErrorMessage = "Số điện thoại không hợp lệ."; return; }

        if (string.IsNullOrWhiteSpace(RequestData.Password) || RequestData.Password.Length < 3)
        { ErrorMessage = "Mật khẩu phải có ít nhất 3 ký tự."; return; }

        if (RequestData.Password != RequestData.ConfirmPassword)
        { ErrorMessage = "Mật khẩu xác nhận không khớp."; return; }

        currentStep = 2;
    }

    private void GoToStep3()
    {
        ErrorMessage = null;

        if (string.IsNullOrWhiteSpace(RequestData.PoiName))
        { ErrorMessage = "Vui lòng nhập Tên địa điểm."; return; }

        if (string.IsNullOrWhiteSpace(RequestData.Address))
        { ErrorMessage = "Vui lòng nhập Địa chỉ."; return; }

        if (string.IsNullOrWhiteSpace(RequestData.BusinessType))
        { ErrorMessage = "Vui lòng chọn Loại hình kinh doanh."; return; }

        currentStep = 3;
    }

    private async Task HandleRegistration()
    {
        IsSubmitting = true;
        ErrorMessage = null;

        try
        {
            using var DbContext = await DbFactory.CreateDbContextAsync();

            var existingUser = await DbContext.AppUsers
                .FirstOrDefaultAsync(u => u.PhoneNumber == RequestData.PhoneNumber || u.Username == RequestData.PhoneNumber);
            
            if (existingUser != null)
            {
                ErrorMessage = "Số điện thoại đã được đăng ký.";
                IsSubmitting = false;
                currentStep = 1; // Quay lại bước 1 để sửa
                return;
            }

            using var transaction = await DbContext.Database.BeginTransactionAsync();
            try
            {
                var maxAgencyIdUser = await DbContext.AppUsers.MaxAsync(u => (int?)u.AgencyId) ?? 0;
                var maxAgencyIdPoi = await DbContext.Pois.IgnoreQueryFilters().MaxAsync(p => (int?)p.AgencyId) ?? 0;
                var maxAgencyIdTour= await DbContext.Tours.IgnoreQueryFilters().MaxAsync(t => (int?)t.AgencyId) ?? 0;
                var maxAgencyIdHistory= await DbContext.UsageHistories.IgnoreQueryFilters().MaxAsync(t => (int?)t.AgencyId) ?? 0;
                
                int newAgencyId = Math.Max(maxAgencyIdUser, Math.Max(maxAgencyIdPoi, Math.Max(maxAgencyIdTour, maxAgencyIdHistory))) + 1;

                var newPoi = new Poi
                {
                    Name = RequestData.PoiName,
                    AgencyId = newAgencyId,
                    Description = "Thông tin đang cập nhật",
                    Latitude = 10.76, 
                    Longitude = 106.70 
                };
                
                DbContext.Pois.Add(newPoi);

                string passwordHash = BCrypt.Net.BCrypt.HashPassword(RequestData.Password);

                var newUser = new AppUser
                {
                    Username = RequestData.PhoneNumber,
                    PasswordHash = passwordHash,
                    PhoneNumber = RequestData.PhoneNumber,
                    FullName = RequestData.FullName,
                    Email = RequestData.Email,
                    Address = RequestData.Address,
                    AgencyId = newAgencyId,
                    Role = "owner",
                    ForcePasswordChange = false,
                    CreatedAt = DateTime.UtcNow
                };

                DbContext.AppUsers.Add(newUser);

                var auditLog = new AppAuditLog
                {
                    Timestamp = DateTime.UtcNow,
                    Action = "register_poi",
                    Details = "500000",
                    UserId = newUser.Username
                };

                DbContext.AppAuditLogs.Add(auditLog);

                await DbContext.SaveChangesAsync();
                await transaction.CommitAsync();

                IsSuccess = true;
            }
            catch (Exception)
            {
                await transaction.RollbackAsync();
                ErrorMessage = "Đã xảy ra lỗi hệ thống, không thể lưu dữ liệu.";
            }
        }
        catch (Exception)
        {
            ErrorMessage = "Lỗi kết nối CSDL.";
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
