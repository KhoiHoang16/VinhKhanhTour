@page "/change-password"
@layout VinhKhanhTour.CMS.Components.Layout.EmptyLayout
@using Microsoft.AspNetCore.Components.Authorization
@using VinhKhanhTour.CMS.Data
@using Microsoft.EntityFrameworkCore
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDbContextFactory<CmsDbContext> DbFactory

<PageTitle>Đổi Mật Khẩu - VinhKhanhTour</PageTitle>

<div class="register-container">
    <div class="register-card">
        <h2>Đổi Mật Khẩu</h2>
        <p class="subtitle">Vì lý do bảo mật, bạn bắt buộc phải thay đổi mật khẩu mặc định trước khi có thể truy cập hệ thống quản trị.</p>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger" style="font-size: 0.9rem;">
                🚨 @ErrorMessage
            </div>
        }
        
        <EditForm Model="@this" OnValidSubmit="HandleChangePassword">
            <div class="form-group">
                <label>Mật khẩu mới</label>
                <InputText @bind-Value="NewPassword" type="password" class="form-control" />
            </div>

            <div class="form-group mb-4">
                <label>Nhập lại mật khẩu mới</label>
                <InputText @bind-Value="ConfirmPassword" type="password" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary w-100" disabled="@IsSubmitting">
                @if (IsSubmitting)
                {
                    <span>⏳ Đang xử lý...</span>
                }
                else
                {
                    <span>🔐 Cập nhật mật khẩu</span>
                }
            </button>
        </EditForm>
    </div>
</div>

<style>
    body { 
        background-color: #0f172a; 
        color: white; 
        margin: 0;
    }
    .register-container { 
        min-height: 100vh; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        background: url('/images/vinh_khanh_food_street_banner.jpg') no-repeat center center; 
        background-size: cover; 
    }
    .register-container::before {
        content: "";
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(15, 23, 42, 0.85);
        z-index: 1;
    }
    .register-card { 
        position: relative;
        z-index: 2;
        background: rgba(30, 41, 59, 0.6); 
        padding: 44px; 
        border-radius: 1.25rem; 
        width: 100%; 
        max-width: 450px; 
        box-shadow: 0 12px 48px rgba(0,0,0,0.5); 
        backdrop-filter: blur(24px); 
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255,255,255,0.08);
    }
    h2 { 
        font-family: 'Space Grotesk', sans-serif;
        background: linear-gradient(135deg, #10b981, #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-weight: 800; 
        text-align: center; 
        margin-bottom: 5px;
    }
    .subtitle { 
        text-align: center; 
        color: #94a3b8; 
        margin-bottom: 25px; 
        font-size: 0.9rem;
    }
    .form-group { 
        margin-bottom: 18px; 
    }
    label { 
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 600; 
        margin-bottom: 8px; 
        color: #e2e8f0; 
        font-size: 0.95rem;
    }
    .form-control { 
        background-color: rgba(15, 23, 42, 0.6); 
        border: 1px solid rgba(255,255,255,0.08); 
        color: white; 
        padding: 14px;
        border-radius: 0.75rem;
        transition: all 0.3s;
    }
    .form-control:focus { 
        background-color: rgba(15, 23, 42, 0.8); 
        border-color: #10b981; 
        color: white; 
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15); 
    }
    .btn-primary { 
        background: linear-gradient(135deg, #10b981, #059669); 
        border: none; 
        font-weight: 700; 
        padding: 14px; 
        font-size: 1.05rem;
        border-radius: 0.85rem;
        transition: all 0.3s;
        box-shadow: 0 4px 14px rgba(16, 185, 129, 0.3);
        color: white;
    }
    .btn-primary:hover { 
        filter: brightness(1.1);
        transform: translateY(-2px);
    }
</style>

@code {
    public string NewPassword { get; set; } = string.Empty;
    public string ConfirmPassword { get; set; } = string.Empty;

    private bool IsSubmitting = false;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.Identity.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login");
        }
    }

    private async Task HandleChangePassword()
    {
        if (string.IsNullOrEmpty(NewPassword))
        {
            ErrorMessage = "Mật khẩu không được để trống.";
            return;
        }

        if (NewPassword != ConfirmPassword)
        {
            ErrorMessage = "Mật khẩu nhập lại không khớp.";
            return;
        }

        IsSubmitting = true;
        ErrorMessage = null;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userClaim = authState.User;
            var agencyIdString = userClaim.FindFirst("agency_id")?.Value;
            
            if (string.IsNullOrEmpty(agencyIdString) || !int.TryParse(agencyIdString, out int agencyId))
            {
                ErrorMessage = "Không thể tìm thấy thông tin định danh của bạn.";
                IsSubmitting = false;
                return;
            }

            using var DbContext = await DbFactory.CreateDbContextAsync();
            var dbUser = await DbContext.AppUsers.FirstOrDefaultAsync(u => u.AgencyId == agencyId);
            if (dbUser == null)
            {
                ErrorMessage = "Không tìm thấy người dùng trong cơ sở dữ liệu.";
                IsSubmitting = false;
                return;
            }

            dbUser.PasswordHash = BCrypt.Net.BCrypt.HashPassword(NewPassword);
            dbUser.ForcePasswordChange = false;
            await DbContext.SaveChangesAsync();

            NavigationManager.NavigateTo("/Account/logout", forceLoad: true);
        }
        catch (Exception)
        {
            ErrorMessage = "Đã xảy ra lỗi cập nhật.";
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
