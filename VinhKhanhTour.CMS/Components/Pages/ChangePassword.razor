@page "/change-password"
@layout VinhKhanhTour.CMS.Components.Layout.EmptyLayout
@using Microsoft.AspNetCore.Components.Authorization
@using VinhKhanhTour.CMS.Data
@using Microsoft.EntityFrameworkCore
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject CmsDbContext DbContext

<PageTitle>Đổi Mật Khẩu - VinhKhanhTour</PageTitle>

<div class="register-container">
    <div class="register-card">
        <h2>Đổi Mật Khẩu</h2>
        <p class="subtitle">Vì lý do bảo mật, bạn bắt buộc phải thay đổi mật khẩu mặc định trước khi có thể truy cập hệ thống quản trị.</p>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger" style="font-size: 0.9rem;">
                🚨 @ErrorMessage
            </div>
        }
        
        <EditForm Model="@this" OnValidSubmit="HandleChangePassword">
            <div class="form-group">
                <label>Mật khẩu mới</label>
                <InputText @bind-Value="NewPassword" type="password" class="form-control" />
            </div>

            <div class="form-group mb-4">
                <label>Nhập lại mật khẩu mới</label>
                <InputText @bind-Value="ConfirmPassword" type="password" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary w-100" disabled="@IsSubmitting">
                @if (IsSubmitting)
                {
                    <span>⏳ Đang xử lý...</span>
                }
                else
                {
                    <span>🔐 Cập nhật mật khẩu</span>
                }
            </button>
        </EditForm>
    </div>
</div>

<style>
    /* Similar styles to Login/Registration to keep layout feeling uniform */
    body { 
        background-color: #121212; 
        color: white; 
        margin: 0;
    }
    .register-container { 
        min-height: 100vh; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        background: url('/images/vinh_khanh_food_street_banner.jpg') no-repeat center center; 
        background-size: cover; 
    }
    .register-container::before {
        content: "";
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.85);
        z-index: 1;
    }
    .register-card { 
        position: relative;
        z-index: 2;
        background: rgba(30, 30, 30, 0.85); 
        padding: 40px; 
        border-radius: 12px; 
        width: 100%; 
        max-width: 450px; 
        box-shadow: 0 8px 32px rgba(0,0,0,0.8); 
        backdrop-filter: blur(12px); 
        border: 1px solid rgba(255,165,0,0.3);
    }
    h2 { 
        color: #FFA500; 
        font-weight: 800; 
        text-align: center; 
        margin-bottom: 5px;
    }
    .subtitle { 
        text-align: center; 
        color: #ccc; 
        margin-bottom: 25px; 
        font-size: 0.9rem;
    }
    .form-group { 
        margin-bottom: 15px; 
    }
    label { 
        font-weight: 600; 
        margin-bottom: 8px; 
        color: #eee; 
        font-size: 0.95rem;
    }
    .form-control { 
        background-color: rgba(0,0,0,0.5); 
        border: 1px solid #555; 
        color: white; 
        padding: 12px;
    }
    .form-control:focus { 
        background-color: rgba(0,0,0,0.8); 
        border-color: #FFA500; 
        color: white; 
        box-shadow: 0 0 0 0.25rem rgba(255, 165, 0, 0.25); 
    }
    .btn-primary { 
        background-color: #FFA500; 
        border: none; 
        font-weight: bold; 
        padding: 12px; 
        font-size: 1.1rem;
        transition: background-color 0.2s;
    }
    .btn-primary:hover { 
        background-color: #e69500; 
    }
</style>

@code {
    public string NewPassword { get; set; } = string.Empty;
    public string ConfirmPassword { get; set; } = string.Empty;

    private bool IsSubmitting = false;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.Identity.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login");
        }
    }

    private async Task HandleChangePassword()
    {
        if (string.IsNullOrEmpty(NewPassword))
        {
            ErrorMessage = "Mật khẩu không được để trống.";
            return;
        }

        if (NewPassword != ConfirmPassword)
        {
            ErrorMessage = "Mật khẩu nhập lại không khớp.";
            return;
        }

        IsSubmitting = true;
        ErrorMessage = null;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userClaim = authState.User;
            var agencyIdString = userClaim.FindFirst("agency_id")?.Value;
            
            if (string.IsNullOrEmpty(agencyIdString) || !int.TryParse(agencyIdString, out int agencyId))
            {
                ErrorMessage = "Không thể tìm thấy thông tin định danh của bạn.";
                IsSubmitting = false;
                return;
            }

            var dbUser = await DbContext.AppUsers.FirstOrDefaultAsync(u => u.AgencyId == agencyId);
            if (dbUser == null)
            {
                ErrorMessage = "Không tìm thấy người dùng trong cơ sở dữ liệu.";
                IsSubmitting = false;
                return;
            }

            dbUser.PasswordHash = BCrypt.Net.BCrypt.HashPassword(NewPassword);
            dbUser.ForcePasswordChange = false;
            await DbContext.SaveChangesAsync();

            NavigationManager.NavigateTo("/Account/logout", forceLoad: true);
        }
        catch (Exception)
        {
            ErrorMessage = "Đã xảy ra lỗi cập nhật.";
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
