@page "/analytics"
@using VinhKhanhTour.Shared.Models
@using VinhKhanhTour.CMS.Services
@using VinhKhanhTour.CMS.Data
@using Microsoft.EntityFrameworkCore
@inject AnalyticsService AnalyticsService
@inject PoiService PoiService
@inject IJSRuntime JSRuntime
@inject IDbContextFactory<CmsDbContext> DbFactory

<PageTitle>Phân tích Dữ liệu - VinhKhanh Tour</PageTitle>

<div class="dashboard-container page-transition">
    <div class="header-section">
        <h1 class="header-title">📊 Phân tích Dữ liệu</h1>
    </div>

    @if (isLoading)
    {
        <div style="text-align: center; padding: 3rem; color: var(--text-secondary);">
            <div class="loading-spinner">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
            </div>
            <p class="loading-pulse">Đang phân tích dữ liệu...</p>
        </div>
    }
    else
    {
        <!-- Summary Cards -->
        <div class="stat-grid">
            <div class="stat-card">
                <h3 class="stat-label">Tổng Lượt Nghe</h3>
                <p class="stat-value">@history.Count</p>
            </div>
            <div class="stat-card">
                <h3 class="stat-label">Tổng Thời Gian</h3>
                <p class="stat-value" style="-webkit-text-fill-color: var(--primary-color); color: var(--primary-color);">@(Math.Round(history.Sum(h => h.ListenDurationSeconds) / 60.0, 1))</p>
                <span class="stat-unit" style="color: var(--text-secondary);">Phút</span>
            </div>
            <div class="stat-card">
                <h3 class="stat-label">TB Nghe/POI</h3>
                <p class="stat-value" style="-webkit-text-fill-color: var(--warning); color: var(--warning);">@avgListenTimeText</p>
                <span class="stat-unit" style="color: var(--text-secondary);">Giây</span>
            </div>
            <div class="stat-card">
                <h3 class="stat-label">Doanh thu phí Đăng ký</h3>
                <p class="stat-value" style="-webkit-text-fill-color: var(--success); color: var(--success);">@totalRevenue.ToString("N0")</p>
                <span class="stat-unit" style="color: var(--text-secondary);">VNĐ</span>
            </div>
            <div class="stat-card">
                <h3 class="stat-label">Quét QR Code</h3>
                <p class="stat-value" style="-webkit-text-fill-color: var(--success); color: var(--success);">@history.Count(h => h.IsQrTriggered)</p>
            </div>
            <div class="stat-card">
                <h3 class="stat-label">Thiết bị</h3>
                <p class="stat-value" style="-webkit-text-fill-color: var(--info); color: var(--info);">@history.Select(h => h.DeviceId).Distinct().Count()</p>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
            <!-- Top Locations Chart -->
            <div class="poi-card">
                <h3 style="margin-top: 0; margin-bottom: 1.5rem; font-weight: 700; font-size: 1.05rem;">🏆 Top Địa Điểm Được Nghe Nhiều Nhất</h3>
                <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                    @if (topPois.Count == 0)
                    {
                        <p style="color: var(--text-secondary);">Chưa có dữ liệu. Bấm "Tạo Dữ Liệu Mẫu".</p>
                    }
                    @foreach (var rank in topPois)
                    {
                        <div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.4rem; font-size: 0.92rem;">
                                <span style="font-weight: 600;">@rank.Name</span>
                                <span style="color: var(--text-secondary);">@rank.Count lượt</span>
                            </div>
                            <div class="progress-bar-bg">
                                <div class="progress-bar-fill" style="width: @Math.Floor(rank.Percent)%;"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Average Listen Time per POI -->
            <div class="poi-card">
                <h3 style="margin-top: 0; margin-bottom: 1.5rem; font-weight: 700; font-size: 1.05rem;">⏱️ Thời Gian TB Nghe Mỗi Địa Điểm</h3>
                <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                    @if (avgTimePois.Count == 0)
                    {
                        <p style="color: var(--text-secondary);">Chưa có dữ liệu.</p>
                    }
                    @foreach (var item in avgTimePois)
                    {
                        <div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.4rem; font-size: 0.92rem;">
                                <span style="font-weight: 600;">@item.Name</span>
                                <span style="color: var(--warning);">@item.AvgSeconds.ToString("F0") giây</span>
                            </div>
                            <div class="progress-bar-bg">
                                <div class="progress-bar-fill" style="width: @Math.Floor(item.Percent)%; background: linear-gradient(90deg, #FBBF24, #F97316);"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- QR vs GPS Comparison -->
        <div class="poi-card" style="margin-bottom: 1.5rem;">
            <h3 style="margin-top: 0; margin-bottom: 1.5rem; font-weight: 700; font-size: 1.05rem;">📱 So sánh QR Code vs GPS</h3>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div style="text-align: center;">
                    <div style="font-size: 2.5rem; font-weight: 800; color: var(--success);">@qrCount</div>
                    <div style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 0.5rem;">Quét QR Code</div>
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: @qrPercent%; background: linear-gradient(90deg, #22C55E, #4ADE80);"></div>
                    </div>
                    <div style="color: var(--text-secondary); font-size: 0.8rem; margin-top: 0.3rem;">@qrPercent.ToString("F1")%</div>
                </div>
                <div style="text-align: center;">
                    <div style="font-size: 2.5rem; font-weight: 800; color: var(--info);">@gpsCount</div>
                    <div style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 0.5rem;">Tự động GPS</div>
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: @gpsPercent%; background: linear-gradient(90deg, #38BDF8, #818CF8);"></div>
                    </div>
                    <div style="color: var(--text-secondary); font-size: 0.8rem; margin-top: 0.3rem;">@gpsPercent.ToString("F1")%</div>
                </div>
            </div>
        </div>

        <!-- Heatmap -->
        <div class="poi-card" style="margin-bottom: 1.5rem; height: 500px; padding: 1rem; display: flex; flex-direction: column;">
            <h3 style="margin-top: 0; margin-bottom: 0.5rem; font-weight: 700; font-size: 1.05rem;">🗺️ Heatmap Vị Trí Người Dùng</h3>
            <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1rem;">Phân bố vị trí người dùng (khu vực Vĩnh Khánh) - Dữ liệu Mẫu</p>
            <div id="heatmap-container" style="flex: 1; min-height: 350px; border-radius: 8px; overflow: hidden;"></div>
        </div>

        <!-- Recent Activity Preview -->
        <div class="poi-card" style="overflow-x: auto;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h3 style="margin: 0; font-weight: 700; font-size: 1.05rem;">🕐 5 Hoạt Động Gần Nhất</h3>
                <a href="/history" style="color: var(--primary-color); text-decoration: none; font-size: 0.88rem; font-weight: 600;">Xem tất cả →</a>
            </div>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Thời gian</th>
                        <th>Địa điểm</th>
                        <th>Nguồn</th>
                        <th style="text-align: right;">Thời lượng</th>
                    </tr>
                </thead>
                <tbody>
                    @if (history.Count == 0)
                    {
                        <tr><td colspan="4" style="padding: 2rem 0; text-align: center; color: var(--text-secondary);">Trống</td></tr>
                    }
                    @foreach (var h in history.Take(5))
                    {
                        <tr>
                            <td>@h.Timestamp.ToLocalTime().ToString("dd/MM HH:mm")</td>
                            <td style="font-weight: 600; color: var(--text-primary);">@(poiDict.ContainsKey(h.PoiId) ? poiDict[h.PoiId] : $"POI #{h.PoiId}")</td>
                            <td>
                                <span class="badge @(h.IsQrTriggered ? "badge-success" : "badge-info")">
                                    @(h.IsQrTriggered ? "📱 QR" : "📍 GPS")
                                </span>
                            </td>
                            <td style="text-align: right;">@h.ListenDurationSeconds giây</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<UsageHistory> history = new();
    private Dictionary<int, string> poiDict = new();
    private Dictionary<int, Poi> poiFullData = new();
    private List<RankData> topPois = new();
    private List<AvgTimeData> avgTimePois = new();
    private string avgListenTimeText = "0";
    private int qrCount = 0;
    private int gpsCount = 0;
    private double qrPercent = 0;
    private double gpsPercent = 0;
    private bool mapInitialized = false;
    private decimal totalRevenue = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || (!isLoading && !mapInitialized))
        {
            if (!isLoading)
            {
                var pointsStr = System.Text.Json.JsonSerializer.Serialize(GetHeatmapPoints());
                await JSRuntime.InvokeVoidAsync("heatmapInterop.initHeatmap", "heatmap-container", pointsStr);
                mapInitialized = true;
            }
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        history = await AnalyticsService.GetUsageHistoryAsync();
        
        var pois = await PoiService.GetPoisAsync();
        poiDict = pois.ToDictionary(p => p.Id, p => p.Name);
        poiFullData = pois.ToDictionary(p => p.Id, p => p);

        if (history.Any())
        {
            // Top POIs
            var maxCount = history.GroupBy(h => h.PoiId).Max(g => g.Count());
            topPois = history.GroupBy(h => h.PoiId)
                             .Select(g => new RankData 
                             { 
                                 Name = poiDict.ContainsKey(g.Key) ? poiDict[g.Key] : $"POI #{g.Key}", 
                                 Count = g.Count(),
                                 Percent = (double)g.Count() * 100 / Math.Max(1, maxCount)
                             })
                             .OrderByDescending(r => r.Count)
                             .Take(5)
                             .ToList();

            // Average listen time per POI
            var maxAvg = history.GroupBy(h => h.PoiId).Max(g => g.Average(h => h.ListenDurationSeconds));
            avgTimePois = history.GroupBy(h => h.PoiId)
                                 .Select(g => new AvgTimeData
                                 {
                                     Name = poiDict.ContainsKey(g.Key) ? poiDict[g.Key] : $"POI #{g.Key}",
                                     AvgSeconds = g.Average(h => h.ListenDurationSeconds),
                                     Percent = g.Average(h => h.ListenDurationSeconds) * 100 / Math.Max(1, maxAvg)
                                 })
                                 .OrderByDescending(a => a.AvgSeconds)
                                 .Take(5)
                                 .ToList();

            // Overall average
            avgListenTimeText = history.Average(h => h.ListenDurationSeconds).ToString("F0");

            // QR vs GPS
            qrCount = history.Count(h => h.IsQrTriggered);
            gpsCount = history.Count(h => !h.IsQrTriggered);
            var total = Math.Max(1, history.Count);
            qrPercent = (double)qrCount * 100 / total;
            gpsPercent = (double)gpsCount * 100 / total;
        }
        else
        {
            topPois = new List<RankData>();
            avgTimePois = new List<AvgTimeData>();
        }

        // Calculate Revenue from DB
        using var dbContext = await DbFactory.CreateDbContextAsync();
        var registerLogs = await dbContext.AppAuditLogs
            .Where(x => x.Action == "register_poi")
            .ToListAsync();
        
        totalRevenue = 0;
        foreach(var log in registerLogs)
        {
            if (decimal.TryParse(log.Details, out decimal rev))
            {
                totalRevenue += rev;
            }
        }

        isLoading = false;
    }
    private object[] GetHeatmapPoints()
    {
        if (history == null || !history.Any())
        {
            return Array.Empty<object>();
        }

        var heatPoints = new List<object>();
        
        // Tạo PoiDict Full để tra cứu tọa độ
        // (poiDict hiện tại chỉ lưu Name, ta dựa vào original pois list)
        
        foreach (var h in history)
        {
            double lat = h.UserLatitude;
            double lng = h.UserLongitude;

            // Nếu DB ghi nhận 0,0 (như QR code không có GPS), 
            // lấy tọa độ của điểm tham quan (POI) tương ứng làm điểm phát sinh
            if ((lat == 0 || lng == 0) && poiFullData.TryGetValue(h.PoiId, out var poi))
            {
                lat = poi.Latitude;
                lng = poi.Longitude;
            }

            if (lat != 0 && lng != 0)
            {
                // Thêm noise nhỏ gọn để heatmap mượt hơn nếu các lượt checkin chụm lại 1 điểm
                // (optional: cộng trừ 0.0001 random offset)
                heatPoints.Add(new double[] { lat, lng, 0.6 });
            }
        }

        return heatPoints.ToArray();
    }

    private async Task GenerateMock()
    {
        mapInitialized = false;
        await AnalyticsService.GenerateMockDataAsync();
        await LoadData();
    }

    public class RankData
    {
        public string Name { get; set; } = string.Empty;
        public int Count { get; set; }
        public double Percent { get; set; }
    }

    public class AvgTimeData
    {
        public string Name { get; set; } = string.Empty;
        public double AvgSeconds { get; set; }
        public double Percent { get; set; }
    }
}
