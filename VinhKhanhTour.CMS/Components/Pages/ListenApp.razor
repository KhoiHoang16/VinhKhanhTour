@page "/listen/{Id:int}"
@attribute [AllowAnonymous]
@layout VinhKhanhTour.CMS.Components.Layout.EmptyLayout
@using VinhKhanhTour.Shared.Models
@using VinhKhanhTour.CMS.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<CmsDbContext> DbFactory
@inject IJSRuntime JSRuntime
@inject IConfiguration Config
@inject NavigationManager NavManager

<PageTitle>@(GetPoiName()) - VinhKhanh Tour Audio</PageTitle>

<div class="listen-app-container">
    @if (isLoading)
    {
        <div class="centered-content">
            <div class="spinner"></div>
            <p>@GetUiString("Loading")</p>
        </div>
    }
    else if (poi == null)
    {
        <div class="centered-content error">
            <div class="icon">🔍</div>
            <h2>@GetUiString("NotFoundTitle")</h2>
            <p>@GetUiString("NotFoundDesc")</p>
        </div>
    }
    else
    {
        <!-- Language Selector -->
        <div class="language-selector @(hasInteracted ? "active" : "")">
            <select class="lang-dropdown" @onchange="ChangeLanguage">
                <option value="vi" selected="@(currentLang == "vi")">🇻🇳 Tiếng Việt</option>
                <option value="en" selected="@(currentLang == "en")">🇬🇧 English</option>
                <option value="es" selected="@(currentLang == "es")">🇪🇸 Español</option>
                <option value="fr" selected="@(currentLang == "fr")">🇫🇷 Français</option>
                <option value="de" selected="@(currentLang == "de")">🇩🇪 Deutsch</option>
                <option value="zh" selected="@(currentLang == "zh")">🇨🇳 中文</option>
                <option value="ja" selected="@(currentLang == "ja")">🇯🇵 日本語</option>
                <option value="ko" selected="@(currentLang == "ko")">🇰🇷 한국어</option>
                <option value="ru" selected="@(currentLang == "ru")">🇷🇺 Русский</option>
                <option value="it" selected="@(currentLang == "it")">🇮🇹 Italiano</option>
                <option value="pt" selected="@(currentLang == "pt")">🇵🇹 Português</option>
            </select>
            <div class="dropdown-icon">🌐</div>
        </div>

        @if (showPaywall)
        {
            <!-- ===== PAYWALL SCREEN ===== -->
            <div class="paywall-container">
                <div class="poi-image-wrapper">
                    <img src="@($"/images/{poi.DisplayImage}")" alt="@GetPoiName()" onerror="this.onerror=null; this.src='/images/vinh_khanh_food_street_banner.jpg';" class="poi-image" />
                    <div class="image-overlay"></div>
                </div>

                <div class="paywall-content">
                    <div class="paywall-icon">🔒</div>
                    <h1>@GetPoiName()</h1>
                    <p class="paywall-subtitle">@GetPaywallString("Subtitle")</p>

                    <div class="paywall-price-card">
                        <div class="price-tag">
                            <span class="price-amount">@FormatPrice(paywallPrice)</span>
                            <span class="price-currency">VND</span>
                        </div>
                        <p class="price-note">@GetPaywallString("Forever")</p>
                    </div>

                    @if (!string.IsNullOrEmpty(paymentError))
                    {
                        <div class="paywall-error">⚠️ @paymentError</div>
                    }

                    <div class="paywall-buttons">
                        <button class="btn-momo" @onclick="PayWithMoMo" disabled="@isProcessingPayment">
                            @if (isProcessingPayment && selectedMethod == "momo")
                            {
                                <span class="btn-spinner"></span>
                            }
                            else
                            {
                                <span>💜 MoMo</span>
                            }
                        </button>
                        <button class="btn-vnpay" @onclick="PayWithVNPay" disabled="@isProcessingPayment">
                            @if (isProcessingPayment && selectedMethod == "vnpay")
                            {
                                <span class="btn-spinner"></span>
                            }
                            else
                            {
                                <span>🏦 VNPay</span>
                            }
                        </button>
                    </div>

                    <div class="paywall-recovery">
                        @if (!showRecoveryForm)
                        {
                            <button class="btn-recovery-toggle" @onclick="() => showRecoveryForm = true">
                                @GetPaywallString("AlreadyBought")
                            </button>
                        }
                        else
                        {
                            <div class="recovery-form">
                                <p>@GetPaywallString("RecoveryDesc")</p>
                                <input type="text" @bind="recoveryContact" placeholder="Email / SĐT" class="recovery-input" />
                                <button class="btn-recover" @onclick="RecoverPurchase" disabled="@isProcessingPayment">
                                    @GetPaywallString("Recover")
                                </button>
                                @if (!string.IsNullOrEmpty(recoveryMessage))
                                {
                                    <p class="recovery-msg @(recoverySuccess ? "success" : "error")">@recoveryMessage</p>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- ===== AUDIO PLAYER (đã mua / đã mở khóa) ===== -->
            <div class="app-content @(hasInteracted ? "active" : "")">
                <div class="poi-image-wrapper">
                    <img src="@($"/images/{poi.DisplayImage}")" alt="@GetPoiName()" onerror="this.onerror=null; this.src='/images/vinh_khanh_food_street_banner.jpg';" class="poi-image" />
                    <div class="image-overlay"></div>
                </div>

                <div class="poi-info">
                    <h1>@GetPoiName()</h1>
                    <p class="category">@GetPoiCategory()</p>
                    <div class="divider"></div>
                    <p class="description">@GetPoiDescription()</p>
                </div>

                <div class="audio-player-card">
                    <div class="now-playing">
                        <div class="audio-animation">
                            <span></span><span></span><span></span><span></span>
                        </div>
                        <span id="playStateText">@GetUiString("Paused")</span>
                    </div>
                    
                    <audio id="audioElement" 
                           src="@GetAudioUrl()" 
                           preload="auto">
                    </audio>

                    <div class="controls">
                        <button id="playPauseBtn" class="btn-play-pause" onclick="toggleAudio()">
                            <svg id="icon-play" viewBox="0 0 24 24" fill="currentColor" style="display:none;"><path d="M8 5v14l11-7z"/></svg>
                            <svg id="icon-pause" viewBox="0 0 24 24" fill="currentColor"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>
                        </button>
                        <button class="btn-restart" onclick="restartAudio()">
                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/></svg>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Splash Screen -->
            <div id="splashScreen" class="splash-screen @(hasInteracted ? "hidden" : "")" @onclick="HandleInteraction">
                <div class="pulse-ring"></div>
                <div class="tap-icon">👉</div>
                <h2 class="tap-text">@GetUiString("TapScreen")</h2>
                <p class="tap-subtext">@GetUiString("TapSubtext")<br/><strong>@GetPoiName()</strong></p>
            </div>
        }
    }
</div>

<style>
    /* ===== PAYWALL STYLES ===== */
    .paywall-container {
        min-height: 100vh; display: flex; flex-direction: column;
        background: linear-gradient(180deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
    }
    .paywall-container .poi-image-wrapper { max-height: 220px; }
    .paywall-content {
        flex: 1; padding: 24px 20px; text-align: center;
        display: flex; flex-direction: column; align-items: center;
    }
    .paywall-icon { font-size: 48px; margin-bottom: 12px; animation: pulse-lock 2s infinite; }
    @@keyframes pulse-lock { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }
    .paywall-content h1 { color: #fff; font-size: 1.6rem; margin: 0 0 6px; }
    .paywall-subtitle { color: rgba(255,255,255,0.7); font-size: 0.95rem; margin: 0 0 20px; }

    .paywall-price-card {
        background: rgba(255,255,255,0.08); backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.15); border-radius: 16px;
        padding: 20px 32px; margin-bottom: 20px;
    }
    .price-tag { display: flex; align-items: baseline; justify-content: center; gap: 6px; }
    .price-amount { font-size: 2.4rem; font-weight: 800; color: #ffd700; }
    .price-currency { font-size: 1rem; color: rgba(255,255,255,0.6); font-weight: 600; }
    .price-note { color: rgba(255,255,255,0.55); font-size: 0.82rem; margin: 8px 0 0; }

    .paywall-error {
        background: rgba(255,100,100,0.15); color: #ff6b6b; padding: 10px 16px;
        border-radius: 10px; margin-bottom: 16px; font-size: 0.85rem; width: 100%;
    }

    .paywall-buttons { display: flex; gap: 12px; width: 100%; max-width: 320px; margin-bottom: 20px; }
    .btn-momo, .btn-vnpay {
        flex: 1; padding: 14px 0; border: none; border-radius: 14px;
        font-size: 1.05rem; font-weight: 700; cursor: pointer;
        transition: transform 0.15s, box-shadow 0.15s; color: #fff;
        display: flex; align-items: center; justify-content: center; min-height: 50px;
    }
    .btn-momo { background: linear-gradient(135deg, #a855f7, #7c3aed); }
    .btn-momo:hover { transform: scale(1.03); box-shadow: 0 4px 20px rgba(168,85,247,0.5); }
    .btn-vnpay { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
    .btn-vnpay:hover { transform: scale(1.03); box-shadow: 0 4px 20px rgba(59,130,246,0.5); }
    .btn-momo:disabled, .btn-vnpay:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    .btn-spinner {
        width: 20px; height: 20px; border: 3px solid rgba(255,255,255,0.3);
        border-top-color: #fff; border-radius: 50%;
        animation: spin 0.7s linear infinite; display: inline-block;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .paywall-recovery { width: 100%; max-width: 320px; }
    .btn-recovery-toggle {
        background: transparent; border: none; color: rgba(255,255,255,0.5);
        font-size: 0.85rem; cursor: pointer; text-decoration: underline;
        padding: 8px; width: 100%;
    }
    .btn-recovery-toggle:hover { color: rgba(255,255,255,0.8); }
    .recovery-form { margin-top: 12px; text-align: left; }
    .recovery-form p { color: rgba(255,255,255,0.6); font-size: 0.85rem; margin: 0 0 8px; }
    .recovery-input {
        width: 100%; padding: 12px 16px; border: 1px solid rgba(255,255,255,0.2);
        border-radius: 10px; background: rgba(255,255,255,0.08); color: #fff;
        font-size: 0.95rem; margin-bottom: 10px; box-sizing: border-box;
    }
    .recovery-input::placeholder { color: rgba(255,255,255,0.35); }
    .btn-recover {
        width: 100%; padding: 12px; border: none; border-radius: 10px;
        background: linear-gradient(135deg, #10b981, #059669);
        color: #fff; font-weight: 600; cursor: pointer; font-size: 0.95rem;
    }
    .btn-recover:disabled { opacity: 0.6; cursor: not-allowed; }
    .recovery-msg { font-size: 0.85rem; margin-top: 8px; }
    .recovery-msg.success { color: #34d399; }
    .recovery-msg.error { color: #f87171; }

    /* Reset & Fonts cho giao diện Mobile-first PWA */
    body, html {
        margin: 0; padding: 0; height: 100%;
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background-color: #121212;
        color: #ffffff;
        overflow: hidden; /* Prevent scrolling on splash */
    }

    .listen-app-container {
        position: relative;
        height: 100vh;
        width: 100vw;
        max-width: 480px; /* Mobile width constraint */
        margin: 0 auto;
        background: #1e1e1e;
        box-shadow: 0 0 20px rgba(0,0,0,0.5);
        display: flex;
        flex-direction: column;
    }

    .centered-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        text-align: center;
        padding: 20px;
    }

    .spinner {
        width: 40px; height: 40px;
        border: 4px solid rgba(255,165,0,0.3);
        border-top-color: #ffa500;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 15px;
    }
    @@keyframes spin { 100% { transform: rotate(360deg); } }

    /* Language Selector */
    .language-selector {
        position: absolute;
        top: 20px;
        right: 20px;
        z-index: 50;
        background: rgba(0, 0, 0, 0.6);
        border-radius: 20px;
        padding: 5px 15px 5px 35px;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 140, 0, 0.5);
        display: flex;
        align-items: center;
        transition: opacity 0.5s;
    }
    .language-selector:not(.active) {
        display: none; /* Hide on splash screen */
    }
    .lang-dropdown {
        background: transparent;
        color: white;
        border: none;
        font-size: 0.9rem;
        font-weight: 600;
        outline: none;
        appearance: none;
        cursor: pointer;
    }
    .lang-dropdown option { background: #1e1e1e; color: white; }
    .dropdown-icon {
        position: absolute;
        left: 10px;
        pointer-events: none;
    }

    /* Splash Screen (Touch to Play) */
    .splash-screen {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: linear-gradient(135deg, #FF8C00 0%, #E65100 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 100;
        transition: opacity 0.5s ease-out, visibility 0.5s;
        cursor: pointer;
    }
    .splash-screen.hidden {
        opacity: 0;
        visibility: hidden;
    }
    .pulse-ring {
        position: absolute;
        width: 120px; height: 120px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        animation: pulse 2s infinite ease-in-out;
    }
    .tap-icon {
        font-size: 3rem;
        z-index: 2;
        animation: bounce 1.5s infinite;
    }
    .tap-text {
        font-size: 1.8rem;
        font-weight: 800;
        margin: 20px 0 5px;
        color: white;
        text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        z-index: 2;
    }
    .tap-subtext {
        font-size: 1rem;
        color: rgba(255,255,255,0.9);
        text-align: center;
        z-index: 2;
    }

    @@keyframes pulse {
        0% { transform: scale(0.8); opacity: 0.8; }
        100% { transform: scale(2); opacity: 0; }
    }
    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
    }

    /* Main App Content */
    .app-content {
        display: flex;
        flex-direction: column;
        height: 100%;
        opacity: 0;
        transform: scale(0.95);
        transition: opacity 0.8s ease, transform 0.8s ease;
        overflow-y: auto;
    }
    .app-content.active {
        opacity: 1;
        transform: scale(1);
    }

    .poi-image-wrapper {
        position: relative;
        width: 100%;
        height: 40vh;
        flex-shrink: 0;
    }
    .poi-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .image-overlay {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 50%;
        background: linear-gradient(to top, #1e1e1e 0%, transparent 100%);
    }

    .poi-info {
        padding: 0 25px;
        margin-top: -30px;
        position: relative;
        z-index: 10;
        flex-grow: 1;
    }
    .poi-info h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 800;
        color: #fff;
        text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    }
    .category {
        display: inline-block;
        background: #FF8C00;
        color: #fff;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-top: 10px;
    }
    .divider {
        height: 2px;
        width: 40px;
        background: #FF8C00;
        margin: 20px 0;
    }
    .description {
        font-size: 1rem;
        line-height: 1.6;
        color: #ccc;
    }

    .audio-player-card {
        background: rgba(255, 255, 255, 0.05);
        border-top: 1px solid rgba(255,255,255,0.1);
        padding: 20px 25px 30px;
        backdrop-filter: blur(10px);
    }

    .now-playing {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 20px;
        font-size: 0.9rem;
        color: #FF8C00;
        font-weight: 600;
    }

    .audio-animation span {
        display: inline-block;
        width: 4px; height: 10px;
        background: #FF8C00;
        margin: 0 2px;
        border-radius: 2px;
        transition: height 0.2s;
    }
    .audio-animation.playing span:nth-child(1) { animation: eq 1.2s ease-in-out infinite 0s; }
    .audio-animation.playing span:nth-child(2) { animation: eq 1.2s ease-in-out infinite 0.2s; }
    .audio-animation.playing span:nth-child(3) { animation: eq 1.2s ease-in-out infinite 0.4s; }
    .audio-animation.playing span:nth-child(4) { animation: eq 1.2s ease-in-out infinite 0.1s; }
    
    @@keyframes eq {
        0%, 100% { height: 10px; }
        50% { height: 25px; }
    }

    .controls {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
    }
    .btn-play-pause {
        width: 70px; height: 70px;
        border-radius: 50%;
        background: linear-gradient(135deg, #FF8C00, #E65100);
        border: none;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(255, 140, 0, 0.4);
        cursor: pointer;
        transition: transform 0.2s;
    }
    .btn-play-pause:active { transform: scale(0.95); }
    .btn-play-pause svg { width: 35px; height: 35px; }

    .btn-restart {
        width: 45px; height: 45px;
        border-radius: 50%;
        background: rgba(255,255,255,0.1);
        border: none;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }
    .btn-restart svg { width: 20px; height: 20px; }

</style>

<script>
    // JS Logic specifically for Audio playback to bypass browser Autoplay policies
    var audioEl = null;
    var ttsText = "";
    var ttsSynthesis = window.speechSynthesis;
    var usingNativeAudio = true;
    var ttsLang = "vi-VN";

    var txtPlaying = "Đang phát...";
    var txtPaused = "Đã tạm dừng";

    function setLabels(playingTxt, pausedTxt) {
        txtPlaying = playingTxt;
        txtPaused = pausedTxt;
        var anim = document.querySelector('.audio-animation');
        updateDomState(anim && anim.classList.contains('playing'));
    }

    function initAudio(hasAudioFile, fallbackScript, localeCode) {
        audioEl = document.getElementById('audioElement');
        if (audioEl) {
            audioEl.load();
        }
        ttsText = fallbackScript;
        usingNativeAudio = hasAudioFile === 'True';
        
        switch (localeCode) {
            case 'en': ttsLang = 'en-US'; break;
            case 'es': ttsLang = 'es-ES'; break;
            case 'fr': ttsLang = 'fr-FR'; break;
            case 'de': ttsLang = 'de-DE'; break;
            case 'zh': ttsLang = 'zh-CN'; break;
            case 'ja': ttsLang = 'ja-JP'; break;
            case 'ko': ttsLang = 'ko-KR'; break;
            case 'ru': ttsLang = 'ru-RU'; break;
            case 'it': ttsLang = 'it-IT'; break;
            case 'pt': ttsLang = 'pt-PT'; break;
            default: ttsLang = 'vi-VN'; break;
        }
        
        if (audioEl && !audioEl.dataset.initialized) {
            audioEl.dataset.initialized = "true";
            audioEl.addEventListener('play', () => updateDomState(true));
            audioEl.addEventListener('pause', () => updateDomState(false));
            audioEl.addEventListener('ended', () => updateDomState(false));
        }
        
        // If it was already playing TTS before language change, stop it
        if (!usingNativeAudio && ttsSynthesis.speaking) {
            ttsSynthesis.cancel(); 
            doPlayAudio(); // Restart in new language
        } else if (usingNativeAudio && audioEl && !audioEl.paused) {
            // Already native audio
            audioEl.play();
        }
    }

    function updateDomState(isPlaying) {
        var el = document.getElementById('playStateText');
        if (el) el.innerText = isPlaying ? txtPlaying : txtPaused;
        
        var anim = document.querySelector('.audio-animation');
        if (anim) {
            if (isPlaying) anim.classList.add('playing');
            else anim.classList.remove('playing');
        }

        var iconPlay = document.getElementById('icon-play');
        var iconPause = document.getElementById('icon-pause');
        if (iconPlay && iconPause) {
            iconPlay.style.display = isPlaying ? 'none' : 'block';
            iconPause.style.display = isPlaying ? 'block' : 'none';
        }
    }

    function doPlayAudio() {
        if (!usingNativeAudio && ttsText) {
            if (ttsSynthesis.speaking) return;
            var utterance = new SpeechSynthesisUtterance(ttsText);
            utterance.lang = ttsLang;
            utterance.onstart = () => updateDomState(true);
            utterance.onend = () => updateDomState(false);
            ttsSynthesis.speak(utterance);
        } else if (audioEl) {
            audioEl.play().catch(e => console.log('Audio error: ' + e));
        }
    }

    function toggleAudio() {
        if (!usingNativeAudio) {
            if (ttsSynthesis.speaking) {
                if (ttsSynthesis.paused) { ttsSynthesis.resume(); updateDomState(true); }
                else { ttsSynthesis.pause(); updateDomState(false); }
            } else {
                doPlayAudio();
            }
        } else if (audioEl) {
            if (audioEl.paused) audioEl.play();
            else audioEl.pause();
        }
    }

    function restartAudio() {
        if (!usingNativeAudio) {
            ttsSynthesis.cancel();
            doPlayAudio();
        } else if (audioEl) {
            audioEl.currentTime = 0;
            audioEl.play();
        }
    }

    // === DEVICE FINGERPRINT (FingerprintJS) ===
    // Sử dụng FingerprintJS để tạo ID thiết bị ổn định, chính xác ~99.5%
    // Browser không cho phép truy cập hardware ID (IMEI, Serial, MAC) vì bảo mật
    // FingerprintJS dùng 40+ tín hiệu: canvas, WebGL, GPU, fonts, screen, audio...
    
    var _cachedFingerprint = null;

    async function getDeviceFingerprint() {
        // Return cached result if available
        if (_cachedFingerprint) return _cachedFingerprint;

        // Try localStorage first (instant)
        var stored = localStorage.getItem('vkt_device_id');
        if (stored) {
            _cachedFingerprint = stored;
            return stored;
        }

        try {
            // Load FingerprintJS CDN
            var FingerprintJS = await import('https://openfpcdn.io/fingerprintjs/v4');
            var fp = await FingerprintJS.load();
            var result = await fp.get();
            
            // result.visitorId = hash ổn định của thiết bị (ví dụ: "a1b2c3d4e5f6g7h8")
            var visitorId = result.visitorId;

            // Detect platform
            var ua = navigator.userAgent || '';
            var platform = 'Web';
            if (/iPhone|iPad|iPod/i.test(ua)) platform = 'iOS';
            else if (/Android/i.test(ua)) platform = 'Android';

            // Format: "Android_a1b2c3d4" hoặc "iOS_e5f6g7h8"
            var deviceId = platform + '_' + visitorId.substring(0, 8);
            
            localStorage.setItem('vkt_device_id', deviceId);
            _cachedFingerprint = deviceId;
            return deviceId;
        } catch (e) {
            console.warn('[Fingerprint] FingerprintJS failed, using fallback:', e);
            
            // Fallback: tạo ID từ các tín hiệu cơ bản
            var ua = navigator.userAgent || '';
            var screen = window.screen;
            var raw = ua + '|' + screen.width + 'x' + screen.height + '|' + screen.colorDepth + '|' + (navigator.language || '') + '|' + new Date().getTimezoneOffset();
            
            var hash = 0;
            for (var i = 0; i < raw.length; i++) {
                hash = ((hash << 5) - hash) + raw.charCodeAt(i);
                hash |= 0;
            }
            
            var platform = 'Web';
            if (/iPhone|iPad|iPod/i.test(ua)) platform = 'iOS';
            else if (/Android/i.test(ua)) platform = 'Android';
            
            var deviceId = platform + '_' + Math.abs(hash).toString(36).substring(0, 8);
            localStorage.setItem('vkt_device_id', deviceId);
            _cachedFingerprint = deviceId;
            return deviceId;
        }
    }
</script>

