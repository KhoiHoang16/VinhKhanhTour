    private string FormatPrice(int price) => price.ToString("N0");

    private async Task PayWithMoMo()
    {
        await InitiatePayment("momo");
    }

    private async Task PayWithVNPay()
    {
        await InitiatePayment("vnpay");
    }

    private async Task InitiatePayment(string method)
    {
        isProcessingPayment = true;
        selectedMethod = method;
        paymentError = null;
        StateHasChanged();

        try
        {
            var deviceId = currentDeviceId ?? "WebApp_Unknown";
            var baseUrl = NavManager.BaseUri.TrimEnd('/');

            using var http = new HttpClient { BaseAddress = new Uri(baseUrl) };
            var payload = new { deviceId, poiId = Id, recoveryContact = (string?)null };

            var endpoint = method == "momo" ? "/api/audio/create-momo-payment" : "/api/audio/create-vnpay-payment";
            var response = await http.PostAsJsonAsync(endpoint, payload);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PaymentUrlResponse>();
                if (!string.IsNullOrEmpty(result?.PayUrl))
                {
                    NavManager.NavigateTo(result.PayUrl, true);
                    return;
                }
            }

            paymentError = currentLang == "vi"
                ? "Không thể tạo link thanh toán. Vui lòng thử lại."
                : "Could not create payment link. Please try again.";
        }
        catch (Exception ex)
        {
            paymentError = $"Error: {ex.Message}";
        }
        finally
        {
            isProcessingPayment = false;
            StateHasChanged();
        }
    }

    private async Task RecoverPurchase()
    {
        if (string.IsNullOrWhiteSpace(recoveryContact)) return;

        isProcessingPayment = true;
        recoveryMessage = null;
        StateHasChanged();

        try
        {
            var deviceId = currentDeviceId ?? "WebApp_Unknown";
            var baseUrl = NavManager.BaseUri.TrimEnd('/');

            using var http = new HttpClient { BaseAddress = new Uri(baseUrl) };
            var payload = new { newDeviceId = deviceId, recoveryContact };
            var response = await http.PostAsJsonAsync("/api/audio/recover", payload);

            if (response.IsSuccessStatusCode)
            {
                recoverySuccess = true;
                recoveryMessage = currentLang == "vi"
                    ? "✅ Khôi phục thành công! Đang mở khóa..."
                    : "✅ Restored successfully! Unlocking...";
                StateHasChanged();
                await Task.Delay(1500);
                showPaywall = false;
                StateHasChanged();
                await Task.Delay(50);
                await PushAudioStateToJs();
            }
            else
            {
                recoverySuccess = false;
                recoveryMessage = currentLang == "vi"
                    ? "❌ Không tìm thấy giao dịch. Kiểm tra lại Email/SĐT."
                    : "❌ No purchases found. Check your Email/Phone.";
            }
        }
        catch
        {
            recoverySuccess = false;
            recoveryMessage = "❌ Lỗi kết nối.";
        }
        finally
        {
            isProcessingPayment = false;
            StateHasChanged();
        }
    }

    private class PaymentUrlResponse
    {
        public string PayUrl { get; set; } = "";
        public string OrderId { get; set; } = "";
    }
