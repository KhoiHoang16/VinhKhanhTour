    protected override async Task OnInitializedAsync()
    {
        using var dbContext = await DbFactory.CreateDbContextAsync();
        poi = await dbContext.Pois
            .IgnoreQueryFilters()
            .Where(p => !p.IsDeleted && p.Id == Id)
            .FirstOrDefaultAsync();

        paywallPrice = Config.GetValue<int>("AudioPaywall:DefaultPriceVND", 20000);

        // Kiểm tra ?unlocked=true từ payment callback
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        var justUnlocked = query.ContainsKey("unlocked");

        if (!justUnlocked && poi != null)
        {
            // Sẽ check access sau khi có DeviceId (OnAfterRenderAsync)
            showPaywall = true; // Default: hiện paywall, check access sẽ ẩn nếu đã mua
        }

        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && poi != null)
        {
            // Lấy DeviceId từ FingerprintJS
            currentDeviceId = await JSRuntime.InvokeAsync<string>("getDeviceFingerprint");
            if (string.IsNullOrEmpty(currentDeviceId)) currentDeviceId = "WebApp_Unknown";

            // Check access từ DB
            using var dbContext = await DbFactory.CreateDbContextAsync();
            var purchase = await dbContext.DevicePurchases
                .Where(p => p.DeviceId == currentDeviceId && p.IsActive)
                .Where(p => p.PoiId == Id || p.PurchaseType == "all_access")
                .Where(p => p.ExpiresAt == null || p.ExpiresAt > DateTime.UtcNow)
                .FirstOrDefaultAsync();

            if (purchase != null)
            {
                showPaywall = false;
                StateHasChanged();
                // Đợi render xong rồi mới push audio
                await Task.Delay(50);
                await PushAudioStateToJs();
            }
            else
            {
                showPaywall = true;
                StateHasChanged();
            }
        }
    }

    private async Task ChangeLanguage(ChangeEventArgs e)
    {
        currentLang = e.Value?.ToString() ?? "vi";
        if (poi != null && hasInteracted)
        {
            // Re-Push to JS when language changes so audio/tts source swaps
            await PushAudioStateToJs();
        }
        StateHasChanged();
    }

    private async Task PushAudioStateToJs()
    {
        string playingTxt = GetUiString("Playing");
        string pausedTxt = GetUiString("Paused");
        await JSRuntime.InvokeVoidAsync("setLabels", playingTxt, pausedTxt);
        
        string audioUrl = GetAudioUrl();
        bool hasNativeFile = !string.IsNullOrEmpty(audioUrl);
        await JSRuntime.InvokeVoidAsync("initAudio", hasNativeFile ? "True" : "False", GetPoiTtsScript(), currentLang);
    }

    private async Task HandleInteraction()
    {
        if (hasInteracted) return;
        
        hasInteracted = true;
        await JSRuntime.InvokeVoidAsync("updateDomState", true);
        await JSRuntime.InvokeVoidAsync("doPlayAudio");

        // Ghi nhận lượt quét QR Code vào CMS database
        if (poi != null)
        {
            try
            {
                // Lấy Device ID thực từ browser (FingerprintJS)
                var deviceId = await JSRuntime.InvokeAsync<string>("getDeviceFingerprint");
                if (string.IsNullOrEmpty(deviceId)) deviceId = "WebApp_Unknown";

                // Context riêng biệt để tránh xung đột với context đọc POI
                using var dbContext = await DbFactory.CreateDbContextAsync();
                dbContext.UsageHistories.Add(new UsageHistory
                {
                    PoiId = poi.Id,
                    AgencyId = poi.AgencyId,
                    ListenDurationSeconds = 0,
                    IsQrTriggered = true,
                    Timestamp = DateTime.UtcNow,
                    DeviceId = deviceId
                });
                await dbContext.SaveChangesAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[ListenApp] Lỗi ghi nhận QR usage: {ex.Message}");
            }
        }
    }

