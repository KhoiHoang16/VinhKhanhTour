@page "/poi/new"
@page "/poi/edit/{Id:int}"
@using VinhKhanhTour.Shared.Models
@using VinhKhanhTour.CMS.Services
@implements IDisposable
@inject IJSRuntime JS
@inject PoiService PoiService
@inject NavigationManager NavManager

<PageTitle>@(IsEdit ? "Sửa Địa điểm" : "Thêm Địa điểm Mới") - VinhKhanh Tour</PageTitle>

<div class="dashboard-container page-transition">
    <div class="header-section">
        <h1 class="header-title">@(IsEdit ? "✏️ Sửa Địa điểm" : "➕ Thêm Địa điểm Mới")</h1>
        <button class="btn btn-secondary" @onclick='() => NavManager.NavigateTo("/")'>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Quay lại
        </button>
    </div>

    @if (isLoading)
    {
        <div style="text-align: center; padding: 3rem; color: var(--text-secondary);">
            <div class="loading-spinner">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
            </div>
            <p class="loading-pulse">Đang tải dữ liệu...</p>
        </div>
    }
    else
    {
        <div class="form-container">
            <EditForm Model="@poi" OnValidSubmit="SavePoi">
                <DataAnnotationsValidator />
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                    <!-- Vietnamese Section -->
                    <div class="form-group" style="grid-column: 1 / -1;">
                        <h3 class="section-title">🇻🇳 Tiếng Việt (Mặc định)</h3>
                    </div>
                    <div class="form-group" style="grid-column: 1 / -1;">
                        <label class="form-label">Tên Địa điểm (VI)</label>
                        <InputText @bind-Value="poi.Name" class="form-control" placeholder="Nhập tên địa điểm..." required />
                    </div>

                    <div class="form-group" style="grid-column: 1 / -1;">
                        <label class="form-label">Mô tả (VI)</label>
                        <InputTextArea @bind-Value="poi.Description" class="form-control" rows="3" placeholder="Mô tả chi tiết về địa điểm này..." />
                    </div>

                    <div class="form-group" style="grid-column: 1 / -1;">
                        <label class="form-label">Kịch bản Audio (VI)</label>
                        <InputTextArea @bind-Value="poi.TtsScript" class="form-control" rows="3" placeholder="Nội dung sẽ được đọc khi phát audio..." />
                    </div>

                    <div class="form-group" style="grid-column: 1 / -1;">
                        <label class="form-label">🎵 Link Audio (VI)</label>
                        <InputText @bind-Value="poi.AudioUrlVi" class="form-control" placeholder="https://... (Link file .mp3)" />
                    </div>

                    <!-- Removed English Section -->
                    <!-- Location Data -->
                    <div class="form-group" style="grid-column: 1 / -1;">
                        <h3 class="section-title">📍 Thông tin Vị trí</h3>
                    </div>

                    <div class="form-group" style="grid-column: 1 / -1;">
                        <div style="display: flex; gap: 1rem; align-items: flex-end;">
                            <div style="flex: 1;">
                                <label class="form-label">Vĩ độ (Latitude)</label>
                                <InputNumber @bind-Value="poi.Latitude" class="form-control" step="0.000001" />
                            </div>
                            <div style="flex: 1;">
                                <label class="form-label">Kinh độ (Longitude)</label>
                                <InputNumber @bind-Value="poi.Longitude" class="form-control" step="0.000001" />
                            </div>
                            <div style="flex-shrink: 0;">
                                <button type="button" class="btn btn-secondary" style="height: 42px; display: flex; align-items: center; gap: 0.5rem;" @onclick="OpenMapModal">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                    Ghim trên bản đồ
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Bán kính (mét)</label>
                        <InputNumber @bind-Value="poi.Radius" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mức ưu tiên</label>
                        <InputNumber @bind-Value="poi.Priority" class="form-control" />
                    </div>

                    <!-- Image -->
                    <div class="form-group" style="grid-column: 1 / -1;">
                        <h3 class="section-title">🖼️ Hình ảnh</h3>
                    </div>

                    <div class="form-group" style="grid-column: 1 / -1;">
                        <label class="form-label">Link Hình ảnh</label>
                        <InputText @bind-Value="poi.ImageUrl" class="form-control" placeholder="Tên file hoặc URL hình ảnh..." />
                    </div>
                </div>

                <div style="margin-top: 2rem; display: flex; justify-content: flex-end; gap: 1rem;">
                    <button type="button" class="btn btn-secondary" @onclick='() => NavManager.NavigateTo("/")'>Hủy</button>
                    <button type="submit" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                        @(IsEdit ? "Lưu thay đổi" : "Tạo Địa điểm")
                    </button>
                </div>
            </EditForm>
        </div>
    }

    <!-- Map Modal -->
    @if (showMapModal)
    {
        <div class="modal-backdrop-custom" @onclick="CloseMapModal"></div>
        <div class="map-modal-container">
            <div class="map-modal-header">
                <h3 style="margin: 0; font-size: 1.2rem;">📍 Chọn vị trí trên bản đồ</h3>
                <button type="button" class="close-btn" @onclick="CloseMapModal">X</button>
            </div>
            <div class="map-modal-body">
                <div id="leafletMap" style="width: 100%; height: 400px; border-radius: 8px;"></div>
                <div style="margin-top: 10px; color: var(--text-secondary); font-size: 0.9rem;">
                    Nhấp vào bản đồ để ghim vị trí. Vĩ độ: <strong>@tempLat</strong>, Kinh độ: <strong>@tempLng</strong>
                </div>
            </div>
            <div class="map-modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="CloseMapModal">Hủy</button>
                <button type="button" class="btn btn-primary" @onclick="ConfirmMapLocation">Xác nhận</button>
            </div>
        </div>
    }
</div>

<style>
    .modal-backdrop-custom {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 1040;
    }
    .map-modal-container {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: white;
        width: 90%;
        max-width: 600px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        z-index: 1050;
        display: flex;
        flex-direction: column;
    }
    .map-modal-header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #eee;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .map-modal-body {
        padding: 1.5rem;
    }
    .map-modal-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #eee;
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
    }
    .close-btn {
        background: none;
        border: none;
        font-size: 1.2rem;
        cursor: pointer;
        color: #666;
    }
</style>

@code {
    [Parameter]
    public int? Id { get; set; }

    private bool IsEdit => Id.HasValue;
    private Poi poi = new Poi();
    private bool isLoading = false;

    private DotNetObjectReference<PoiForm>? dotNetRef;
    private bool showMapModal = false;
    private double tempLat;
    private double tempLng;

    public void Dispose()
    {
        dotNetRef?.Dispose();
    }

    private async Task OpenMapModal()
    {
        tempLat = poi.Latitude != 0 ? Math.Round(poi.Latitude, 6) : 10.762622;
        tempLng = poi.Longitude != 0 ? Math.Round(poi.Longitude, 6) : 106.660172;
        showMapModal = true;
        StateHasChanged();

        await Task.Delay(100); 
        await JS.InvokeVoidAsync("mapInterop.initMap", "leafletMap", dotNetRef, tempLat, tempLng);
    }

    private void CloseMapModal()
    {
        showMapModal = false;
    }

    private void ConfirmMapLocation()
    {
        poi.Latitude = tempLat;
        poi.Longitude = tempLng;
        showMapModal = false;
    }

    [JSInvokable]
    public void UpdateCoordinates(double lat, double lng)
    {
        tempLat = Math.Round(lat, 6);
        tempLng = Math.Round(lng, 6);
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        dotNetRef = DotNetObjectReference.Create(this);

        if (IsEdit && Id.HasValue)
        {
            isLoading = true;
            try
            {
                var existingPoi = await PoiService.GetPoiAsync(Id.Value);
                if (existingPoi != null)
                {
                    poi = existingPoi;
                }
            }
            finally
            {
                isLoading = false;
            }
        }
    }

    private async Task SavePoi()
    {
        if (IsEdit)
        {
            await PoiService.UpdatePoiAsync(poi);
        }
        else
        {
            await PoiService.CreatePoiAsync(poi);
        }
        NavManager.NavigateTo("/");
    }
}
