@page "/admin/approvals"
@using VinhKhanhTour.Shared.Models
@using VinhKhanhTour.CMS.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject PoiService PoiService
@inject NavigationManager NavManager

<PageTitle>Phê duyệt nội dung - VinhKhanh Tour</PageTitle>

<div class="dashboard-container page-transition">
    <div class="header-section">
        <h1 class="header-title">✅ Phê duyệt nội dung</h1>
        <div style="display: flex; align-items: center; gap: 1rem;">
            @if (pendingPois != null)
            {
                <span style="background: #f59e0b22; color: #f59e0b; border: 1px solid #f59e0b44; padding: 6px 14px; border-radius: 20px; font-weight: 700; font-size: 0.9rem;">
                    @pendingPois.Count POI chờ duyệt
                </span>
            }
        </div>
    </div>

    @if (pendingPois == null)
    {
        <div style="text-align: center; padding: 3rem; color: var(--text-secondary);">
            <div class="loading-spinner">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
            </div>
            <p class="loading-pulse">Đang tải danh sách chờ duyệt...</p>
        </div>
    }
    else if (!pendingPois.Any())
    {
        <div class="form-container" style="text-align: center; padding: 4rem 2rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem; opacity: 0.6;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <h2 style="color: var(--text-primary);">Không có nội dung chờ duyệt</h2>
            <p style="color: var(--text-secondary);">Tất cả POI đã được xử lý. Quay lại kiểm tra sau nhé!</p>
        </div>
    }
    else
    {
        <div class="poi-grid">
            @foreach (var poi in pendingPois)
            {
                <div class="poi-card" @key="poi.Id" style="border-left: 4px solid #f59e0b;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                        <h3 class="poi-title" style="margin: 0; flex: 1;">@poi.Name</h3>
                        <span style="background: #f59e0b22; color: #f59e0b; border: 1px solid #f59e0b44; font-size: 0.75rem; padding: 4px 10px; border-radius: 20px; white-space: nowrap;">⏳ Pending</span>
                    </div>

                    <p class="poi-description">@(string.IsNullOrWhiteSpace(poi.Description) ? "Chưa có mô tả." : poi.Description)</p>

                    <div class="poi-meta">
                        <div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: -2px; margin-right: 4px;"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"></polygon><line x1="8" y1="2" x2="8" y2="18"></line><line x1="16" y1="6" x2="16" y2="22"></line></svg>
                            @poi.Latitude.ToString("F4"), @poi.Longitude.ToString("F4")
                        </div>
                        <div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: -2px; margin-right: 4px;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                            Bán kính: @poi.Radius m
                        </div>
                        @if (poi.AgencyId.HasValue)
                        {
                            <div>
                                <span style="color: var(--primary-color);">🏪</span> Agency #@poi.AgencyId
                            </div>
                        }
                    </div>

                    @* Audio & Translation badges *@
                    <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;">
                        @if (!string.IsNullOrWhiteSpace(poi.AudioUrlVi))
                        {
                            <span class="badge badge-success">🎵 Audio VI</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(poi.AudioUrlEn))
                        {
                            <span class="badge badge-success">🎵 Audio EN</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(poi.NameEn))
                        {
                            <span class="badge badge-info">🌐 EN</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(poi.ImageUrl))
                        {
                            <span class="badge badge-info">🖼️ Có ảnh</span>
                        }
                    </div>

                    @* Action buttons *@
                    <div style="display: flex; gap: 0.75rem;">
                        <button class="btn" style="flex: 1; background: #22c55e; color: white; border: none; font-weight: 700;" @onclick="() => ApprovePoi(poi)">
                            ✅ Duyệt
                        </button>
                        <button class="btn" style="flex: 1; background: #ef4444; color: white; border: none; font-weight: 700;" @onclick="() => ShowRejectModal(poi)">
                            ❌ Từ chối
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* === REJECT MODAL (2026 Glassmorphism Pill UI) === *@
@if (showRejectModal && poiToReject != null)
{
    <div class="reject-overlay" @onclick="CloseRejectModal">
        <div class="reject-modal" @onclick:stopPropagation="true">
            <div class="reject-icon-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="12"></line>
                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
            </div>

            <h3 class="reject-title">Từ chối duyệt địa điểm</h3>
            <p class="reject-subtitle">
                Vui lòng cung cấp lý do để chủ quán <strong>"@poiToReject.Name"</strong> có thể khắc phục.
            </p>

            <div class="reject-form-group">
                <label class="reject-label">📝 Lý do từ chối <span style="color: #f87171;">*</span></label>
                <textarea @bind="rejectNote" class="reject-textarea" rows="4" placeholder="VD: Hình ảnh biển hiệu bị mờ, vui lòng cập nhật lại..."></textarea>
                @if (showRejectError)
                {
                    <div class="reject-field-error">⚠ Vui lòng nhập lý do từ chối.</div>
                }
            </div>

            <div class="reject-actions">
                <button class="reject-btn-cancel" @onclick="CloseRejectModal">Hủy</button>
                <button class="reject-btn-confirm" @onclick="ConfirmReject">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
                    Xác nhận từ chối
                </button>
            </div>
        </div>
    </div>
}

@* === TOAST NOTIFICATION (Glassmorphism Float) === *@
@if (!string.IsNullOrEmpty(toastMessage))
{
    <div class="glass-toast @(toastColor == "#22c55e" ? "toast-success" : "toast-danger")">
        <div class="toast-icon">
            @if (toastColor == "#22c55e")
            {
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            }
            else
            {
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
            }
        </div>
        <span class="toast-text">@toastMessage</span>
    </div>
}

<style>
    /* === REJECT MODAL (Pill Glassmorphism) === */
    .reject-overlay {
        position: fixed; inset: 0;
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        display: flex; align-items: center; justify-content: center;
        z-index: 1000; animation: fadeIn 0.25s ease;
    }
    .reject-modal {
        background: rgba(30, 41, 59, 0.7);
        backdrop-filter: blur(32px); -webkit-backdrop-filter: blur(32px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 1.5rem; padding: 2rem 2rem 1.75rem;
        width: 90%; max-width: 460px;
        box-shadow: 0 24px 64px rgba(0,0,0,0.4);
        animation: modalSlideUp 0.3s ease;
    }
    .reject-icon-wrap {
        width: 56px; height: 56px; border-radius: 50%;
        background: rgba(245, 158, 11, 0.12);
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.25rem;
    }
    .reject-title {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 1.2rem; font-weight: 700;
        color: #f1f5f9; text-align: center; margin: 0 0 0.5rem;
    }
    .reject-subtitle {
        color: #94a3b8; text-align: center;
        font-size: 0.9rem; line-height: 1.5; margin: 0 0 1.5rem;
    }
    .reject-subtitle strong { color: #e2e8f0; }
    .reject-form-group { margin-bottom: 1.5rem; }
    .reject-label {
        display: block; font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 600; color: #e2e8f0; font-size: 0.9rem; margin-bottom: 0.5rem;
    }
    .reject-textarea {
        width: 100%; padding: 14px 18px;
        background: rgba(15, 23, 42, 0.5); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 1rem; color: #f1f5f9; font-family: 'Inter', sans-serif;
        font-size: 0.92rem; line-height: 1.5; resize: vertical; outline: none;
        transition: all 0.3s;
    }
    .reject-textarea:focus {
        border-color: #f59e0b; box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.1);
        background: rgba(15, 23, 42, 0.7);
    }
    .reject-textarea::placeholder { color: rgba(255,255,255,0.25); }
    .reject-field-error { color: #f87171; font-size: 0.82rem; margin-top: 0.5rem; }
    .reject-actions { display: flex; gap: 0.75rem; }
    .reject-btn-cancel {
        flex: 1; padding: 12px 20px; border-radius: 50px;
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
        color: #94a3b8; font-weight: 600; font-size: 0.92rem; cursor: pointer;
        transition: all 0.3s;
    }
    .reject-btn-cancel:hover { background: rgba(255,255,255,0.1); color: #e2e8f0; }
    .reject-btn-confirm {
        flex: 1; padding: 12px 20px; border: none; border-radius: 50px;
        background: linear-gradient(135deg, #f59e0b, #ef4444);
        color: #fff; font-weight: 700; font-size: 0.92rem; cursor: pointer;
        display: flex; align-items: center; justify-content: center; gap: 6px;
        transition: all 0.3s; box-shadow: 0 4px 16px rgba(245, 158, 11, 0.25);
    }
    .reject-btn-confirm:hover {
        transform: translateY(-2px); box-shadow: 0 8px 24px rgba(245, 158, 11, 0.35);
    }

    /* === TOAST (Glassmorphism Float) === */
    .glass-toast {
        position: fixed; bottom: 2rem; right: 2rem;
        background: rgba(30, 41, 59, 0.75);
        backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255,255,255,0.1); border-radius: 50px;
        padding: 0.85rem 1.5rem; display: flex; align-items: center; gap: 0.75rem;
        box-shadow: 0 12px 40px rgba(0,0,0,0.35); z-index: 2000;
        animation: toastSlideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1); max-width: 420px;
    }
    .glass-toast.toast-success { border-color: rgba(16, 185, 129, 0.25); }
    .glass-toast.toast-danger { border-color: rgba(245, 158, 11, 0.25); }
    .toast-icon {
        width: 36px; height: 36px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .toast-success .toast-icon { background: rgba(16, 185, 129, 0.15); }
    .toast-danger .toast-icon { background: rgba(245, 158, 11, 0.15); }
    .toast-text { color: #e2e8f0; font-weight: 600; font-size: 0.9rem; line-height: 1.4; }

    @@keyframes modalSlideUp {
        from { opacity: 0; transform: translateY(24px) scale(0.96); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
    @@keyframes toastSlideIn {
        from { opacity: 0; transform: translateX(40px); }
        to { opacity: 1; transform: translateX(0); }
    }
</style>

@code {
    private List<Poi>? pendingPois;
    private bool showRejectModal = false;
    private Poi? poiToReject;
    private string rejectNote = string.Empty;
    private bool showRejectError = false;
    private string toastMessage = string.Empty;
    private string toastColor = "#22c55e";

    protected override async Task OnInitializedAsync()
    {
        await LoadPendingPois();
    }

    private async Task LoadPendingPois()
    {
        try
        {
            pendingPois = await PoiService.GetPendingPoisAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading pending POIs: {ex.Message}");
            pendingPois = new List<Poi>();
        }
    }

    private async Task ApprovePoi(Poi poi)
    {
        var result = await PoiService.ApprovePoiAsync(poi.Id);
        if (result)
        {
            await ShowToast($"✅ \"{poi.Name}\" đã được duyệt!", "#22c55e");
            await LoadPendingPois();
        }
    }

    private void ShowRejectModal(Poi poi)
    {
        poiToReject = poi;
        rejectNote = string.Empty;
        showRejectError = false;
        showRejectModal = true;
    }

    private void CloseRejectModal()
    {
        showRejectModal = false;
        poiToReject = null;
        rejectNote = string.Empty;
        showRejectError = false;
    }

    private async Task ConfirmReject()
    {
        if (string.IsNullOrWhiteSpace(rejectNote))
        {
            showRejectError = true;
            return;
        }

        if (poiToReject != null)
        {
            var result = await PoiService.RejectPoiAsync(poiToReject.Id, rejectNote.Trim());
            if (result)
            {
                await ShowToast($"❌ \"{poiToReject.Name}\" đã bị từ chối.", "#ef4444");
                CloseRejectModal();
                await LoadPendingPois();
            }
        }
    }

    private async Task ShowToast(string message, string color)
    {
        toastMessage = message;
        toastColor = color;
        StateHasChanged();
        await Task.Delay(3000);
        toastMessage = string.Empty;
        StateHasChanged();
    }
}
