@page "/"
@using VinhKhanhTour.Shared.Models
@using VinhKhanhTour.CMS.Services
@inject PoiService PoiService
@inject NavigationManager NavManager
@inject ICurrentUserService CurrentUser

<PageTitle>Quản lý Địa điểm - VinhKhanh Tour</PageTitle>

<div class="dashboard-container page-transition">
    <div class="header-section">
        <h1 class="header-title">📍 Quản lý Địa điểm</h1>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
            @if (CurrentUser.IsSystemAdmin && pendingCount > 0)
            {
                <span class="pending-badge" @onclick="() => activeTab = Tab.Approval" style="cursor: pointer;">
                    ⏳ @pendingCount chờ duyệt
                </span>
            }
            <button class="btn btn-primary" @onclick='() => NavManager.NavigateTo("/poi/new")'>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Thêm Địa điểm
            </button>
        </div>
    </div>

    @* === TABS (Admin only sees both tabs) === *@
    @if (CurrentUser.IsSystemAdmin)
    {
        <div class="tab-bar">
            <button class="tab-btn @(activeTab == Tab.PoiList ? "active" : "")" @onclick="() => activeTab = Tab.PoiList">
                📋 Danh sách POI <span class="tab-count">@(pois?.Count ?? 0)</span>
            </button>
            <button class="tab-btn @(activeTab == Tab.Approval ? "active" : "")" @onclick="() => activeTab = Tab.Approval">
                ✅ Duyệt nội dung
                @if (pendingCount > 0)
                {
                    <span class="tab-count pending">@pendingCount</span>
                }
            </button>
        </div>
    }

    @* ====== TAB: POI LIST ====== *@
    @if (activeTab == Tab.PoiList)
    {
        @if (pois == null)
        {
            <div style="text-align: center; padding: 3rem; color: var(--text-secondary);">
                <div class="loading-spinner">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
                </div>
                <p class="loading-pulse">Đang tải danh sách địa điểm...</p>
            </div>
        }
        else if (!pois.Any())
        {
            <div class="form-container" style="text-align: center; padding: 4rem 2rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem; opacity: 0.6;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                <h2 style="color: var(--text-primary);">Chưa có Địa điểm nào</h2>
                <p style="color: var(--text-secondary); margin-bottom: 2rem;">Hãy bắt đầu bằng cách thêm địa điểm du lịch đầu tiên.</p>
                <button class="btn btn-primary" @onclick='() => NavManager.NavigateTo("/poi/new")'>Tạo Địa điểm</button>
            </div>
        }
        else
        {
            <div style="margin-bottom: 1.5rem; color: var(--text-secondary); font-size: 0.9rem;">
                Tổng cộng: <strong style="color: var(--primary-color);">@pois.Count</strong> địa điểm
            </div>

            <div class="poi-grid">
                @foreach (var poi in pois)
                {
                    <div class="poi-card" @key="poi.Id">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                            <h3 class="poi-title" style="margin: 0; flex: 1;">@poi.DisplayName</h3>
                            @switch (poi.ApprovalStatus)
                            {
                                case ApprovalStatus.Pending:
                                    <span class="badge" style="background: #f59e0b22; color: #f59e0b; border: 1px solid #f59e0b44; font-size: 0.75rem; padding: 4px 10px; border-radius: 20px; white-space: nowrap;">⏳ Chờ duyệt</span>
                                    break;
                                case ApprovalStatus.Approved:
                                    <span class="badge" style="background: #22c55e22; color: #22c55e; border: 1px solid #22c55e44; font-size: 0.75rem; padding: 4px 10px; border-radius: 20px; white-space: nowrap;">✅ Đã duyệt</span>
                                    break;
                                case ApprovalStatus.Rejected:
                                    <span class="badge" style="background: #ef444422; color: #ef4444; border: 1px solid #ef444444; font-size: 0.75rem; padding: 4px 10px; border-radius: 20px; white-space: nowrap;">❌ Bị từ chối</span>
                                    break;
                            }
                        </div>
                        <p class="poi-description">@(string.IsNullOrWhiteSpace(poi.DisplayDescription) ? "Chưa có mô tả." : poi.DisplayDescription)</p>
                        
                        <div class="poi-meta">
                            <div>
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: -2px; margin-right: 4px;"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"></polygon><line x1="8" y1="2" x2="8" y2="18"></line><line x1="16" y1="6" x2="16" y2="22"></line></svg>
                                @poi.Latitude.ToString("F4"), @poi.Longitude.ToString("F4")
                            </div>
                            <div>
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: -2px; margin-right: 4px;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                Bán kính: @poi.Radius m
                            </div>
                        </div>

                        <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;">
                            @if (!string.IsNullOrWhiteSpace(poi.AudioUrlVi))
                            {
                                <span class="badge badge-success">🎵 Audio VI</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">❌ Audio VI</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(poi.AudioUrlEn))
                            {
                                <span class="badge badge-success">🎵 Audio EN</span>
                            }
                            else
                            {
                                <span class="badge badge-warning">⚠ Audio EN</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(poi.NameEn))
                            {
                                <span class="badge badge-info">🌐 EN</span>
                            }
                        </div>

                        @if (poi.ApprovalStatus == ApprovalStatus.Rejected && !string.IsNullOrWhiteSpace(poi.AdminNote))
                        {
                            <div style="background: #ef444415; border: 1px solid #ef444433; border-radius: 8px; padding: 0.75rem; margin-bottom: 1rem; font-size: 0.85rem;">
                                <strong style="color: #ef4444;">📝 Lý do từ chối:</strong>
                                <span style="color: var(--text-secondary); margin-left: 0.5rem;">@poi.AdminNote</span>
                            </div>
                        }

                        <div class="poi-actions">
                            <button class="btn btn-secondary" @onclick="() => EditPoi(poi.Id)">
                                ✏️ Sửa
                            </button>
                            <button class="btn btn-danger" @onclick="() => ConfirmDelete(poi)">
                                🗑️ Xóa
                            </button>
                            @* Admin: inline approve/reject for pending POIs *@
                            @if (CurrentUser.IsSystemAdmin && poi.ApprovalStatus == ApprovalStatus.Pending)
                            {
                                <button class="btn" style="background: #22c55e; color: white; border: none; font-weight: 600; font-size: 0.85rem;" @onclick="() => ApprovePoi(poi)">
                                    ✅ Duyệt
                                </button>
                                <button class="btn" style="background: #ef4444; color: white; border: none; font-weight: 600; font-size: 0.85rem;" @onclick="() => ShowRejectModal(poi)">
                                    ❌ Từ chối
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }

    @* ====== TAB: APPROVAL (Admin only) ====== *@
    @if (activeTab == Tab.Approval && CurrentUser.IsSystemAdmin)
    {
        @if (pendingPois == null)
        {
            <div style="text-align: center; padding: 3rem; color: var(--text-secondary);">
                <div class="loading-spinner">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
                </div>
                <p class="loading-pulse">Đang tải danh sách chờ duyệt...</p>
            </div>
        }
        else if (!pendingPois.Any())
        {
            <div class="form-container" style="text-align: center; padding: 4rem 2rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem; opacity: 0.6;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                <h2 style="color: var(--text-primary);">Không có nội dung chờ duyệt</h2>
                <p style="color: var(--text-secondary);">Tất cả POI đã được xử lý. 🎉</p>
            </div>
        }
        else
        {
            <div style="margin-bottom: 1.5rem; color: var(--text-secondary); font-size: 0.9rem;">
                <strong style="color: #f59e0b;">@pendingPois.Count</strong> POI đang chờ duyệt
            </div>

            <div class="poi-grid">
                @foreach (var poi in pendingPois)
                {
                    <div class="poi-card" @key="poi.Id" style="border-left: 4px solid #f59e0b;">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                            <h3 class="poi-title" style="margin: 0; flex: 1;">@poi.Name</h3>
                            <span style="background: #f59e0b22; color: #f59e0b; border: 1px solid #f59e0b44; font-size: 0.75rem; padding: 4px 10px; border-radius: 20px; white-space: nowrap;">⏳ Pending</span>
                        </div>

                        <p class="poi-description">@(string.IsNullOrWhiteSpace(poi.Description) ? "Chưa có mô tả." : poi.Description)</p>

                        <div class="poi-meta">
                            <div>📍 @poi.Latitude.ToString("F4"), @poi.Longitude.ToString("F4")</div>
                            <div>⭕ Bán kính: @poi.Radius m</div>
                            @if (poi.AgencyId.HasValue)
                            {
                                <div>🏪 Agency #@poi.AgencyId</div>
                            }
                        </div>

                        <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;">
                            @if (!string.IsNullOrWhiteSpace(poi.AudioUrlVi))
                            {
                                <span class="badge badge-success">🎵 Audio VI</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(poi.AudioUrlEn))
                            {
                                <span class="badge badge-success">🎵 Audio EN</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(poi.NameEn))
                            {
                                <span class="badge badge-info">🌐 EN</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(poi.ImageUrl))
                            {
                                <span class="badge badge-info">🖼️ Có ảnh</span>
                            }
                        </div>

                        <div style="display: flex; gap: 0.75rem;">
                            <button class="btn" style="flex: 1; background: #22c55e; color: white; border: none; font-weight: 700;" @onclick="() => ApprovePoi(poi)">
                                ✅ Duyệt
                            </button>
                            <button class="btn" style="flex: 1; background: #ef4444; color: white; border: none; font-weight: 700;" @onclick="() => ShowRejectModal(poi)">
                                ❌ Từ chối
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@* === DELETE MODAL === *@
@if (ShowDeleteConfirm && poiToDelete != null)
{
    <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 1000; animation: fadeIn 0.2s;">
        <div class="form-container" style="max-width: 420px; text-align: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            <h3 style="margin-top: 0; color: var(--text-primary);">Xóa Địa điểm?</h3>
            <p style="color: var(--text-secondary); margin-bottom: 2rem;">Bạn có chắc muốn xóa "<strong>@poiToDelete.Name</strong>"? Hành động này không thể hoàn tác.</p>
            <div style="display: flex; gap: 1rem;">
                <button class="btn btn-secondary" style="flex: 1;" @onclick="CancelDelete">Hủy</button>
                <button class="btn btn-danger" style="flex: 1; background: var(--danger); color: white;" @onclick="DeletePoi">Xóa</button>
            </div>
        </div>
    </div>
}

@* === REJECT MODAL === *@
@if (showRejectModal && poiToReject != null)
{
    <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 1000; animation: fadeIn 0.2s;">
        <div class="form-container" style="max-width: 480px; width: 90%;">
            <div style="text-align: center; margin-bottom: 1.5rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
            </div>
            <h3 style="margin: 0 0 0.5rem 0; color: var(--text-primary); text-align: center;">Từ chối POI</h3>
            <p style="color: var(--text-secondary); text-align: center; margin-bottom: 1.5rem;">
                "<strong>@poiToReject.Name</strong>"
            </p>

            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label class="form-label">📝 Lý do từ chối <span style="color: #ef4444;">*</span></label>
                <textarea @bind="rejectNote" class="form-control" rows="4" placeholder="Nhập lý do từ chối để Chủ quán sửa lại... (bắt buộc)" style="resize: vertical;"></textarea>
                @if (showRejectError)
                {
                    <div style="color: #ef4444; font-size: 0.85rem; margin-top: 0.5rem;">⚠ Vui lòng nhập lý do từ chối.</div>
                }
            </div>

            <div style="display: flex; gap: 1rem;">
                <button class="btn btn-secondary" style="flex: 1;" @onclick="CloseRejectModal">Hủy</button>
                <button class="btn" style="flex: 1; background: #ef4444; color: white; border: none; font-weight: 700;" @onclick="ConfirmReject">
                    Xác nhận từ chối
                </button>
            </div>
        </div>
    </div>
}

@* === TOAST === *@
@if (!string.IsNullOrEmpty(toastMessage))
{
    <div style="position: fixed; bottom: 2rem; right: 2rem; background: @toastColor; color: white; padding: 1rem 1.5rem; border-radius: 12px; font-weight: 600; box-shadow: 0 8px 32px rgba(0,0,0,0.3); z-index: 2000; animation: fadeIn 0.3s; max-width: 400px;">
        @toastMessage
    </div>
}

<style>
    .tab-bar {
        display: flex; gap: 4px; margin-bottom: 1.5rem;
        background: var(--card-bg, rgba(255,255,255,0.04));
        border-radius: 12px; padding: 4px;
        border: 1px solid var(--border-color, rgba(255,255,255,0.08));
    }
    .tab-btn {
        flex: 1; padding: 10px 16px; border: none; border-radius: 10px;
        background: transparent; color: var(--text-secondary);
        font-size: 0.9rem; font-weight: 600; cursor: pointer;
        transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px;
    }
    .tab-btn:hover { color: var(--text-primary); background: rgba(255,255,255,0.04); }
    .tab-btn.active {
        background: var(--primary-color); color: #000; 
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }
    .tab-count {
        background: rgba(255,255,255,0.15); padding: 2px 8px;
        border-radius: 10px; font-size: 0.75rem; font-weight: 700;
    }
    .tab-btn.active .tab-count { background: rgba(0,0,0,0.15); }
    .tab-count.pending {
        background: #ef4444; color: white;
        animation: pulse 2s infinite;
    }
    .pending-badge {
        background: #f59e0b22; color: #f59e0b; border: 1px solid #f59e0b44;
        padding: 6px 14px; border-radius: 20px; font-weight: 700; font-size: 0.85rem;
        transition: all 0.2s;
    }
    .pending-badge:hover { background: #f59e0b33; }
</style>

@code {
    private enum Tab { PoiList, Approval }
    private Tab activeTab = Tab.PoiList;

    private List<Poi>? pois;
    private List<Poi>? pendingPois;
    private int pendingCount = 0;

    // Delete 
    private bool ShowDeleteConfirm = false;
    private Poi? poiToDelete;

    // Reject
    private bool showRejectModal = false;
    private Poi? poiToReject;
    private string rejectNote = string.Empty;
    private bool showRejectError = false;

    // Toast
    private string toastMessage = string.Empty;
    private string toastColor = "#22c55e";

    protected override async Task OnInitializedAsync()
    {
        await LoadPois();

        if (CurrentUser.IsSystemAdmin)
        {
            await LoadPendingPois();
        }
    }

    private async Task LoadPois()
    {
        try
        {
            pois = await PoiService.GetPoisAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading POIs: {ex.Message}");
        }
    }

    private async Task LoadPendingPois()
    {
        try
        {
            pendingPois = await PoiService.GetPendingPoisAsync();
            pendingCount = pendingPois?.Count ?? 0;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading pending POIs: {ex.Message}");
            pendingPois = new List<Poi>();
            pendingCount = 0;
        }
    }

    private void EditPoi(int id)
    {
        NavManager.NavigateTo($"/poi/edit/{id}");
    }

    // === DELETE ===
    private void ConfirmDelete(Poi poi)
    {
        poiToDelete = poi;
        ShowDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        ShowDeleteConfirm = false;
        poiToDelete = null;
    }

    private async Task DeletePoi()
    {
        if (poiToDelete != null)
        {
            await PoiService.DeletePoiAsync(poiToDelete.Id);
            await LoadPois();
            if (CurrentUser.IsSystemAdmin) await LoadPendingPois();
        }
        CancelDelete();
    }

    // === APPROVAL (Admin) ===
    private async Task ApprovePoi(Poi poi)
    {
        var result = await PoiService.ApprovePoiAsync(poi.Id);
        if (result)
        {
            await ShowToast($"✅ \"{poi.Name}\" đã được duyệt!", "#22c55e");
            await LoadPois();
            await LoadPendingPois();
        }
    }

    private void ShowRejectModal(Poi poi)
    {
        poiToReject = poi;
        rejectNote = string.Empty;
        showRejectError = false;
        showRejectModal = true;
    }

    private void CloseRejectModal()
    {
        showRejectModal = false;
        poiToReject = null;
        rejectNote = string.Empty;
        showRejectError = false;
    }

    private async Task ConfirmReject()
    {
        if (string.IsNullOrWhiteSpace(rejectNote))
        {
            showRejectError = true;
            return;
        }

        if (poiToReject != null)
        {
            var result = await PoiService.RejectPoiAsync(poiToReject.Id, rejectNote.Trim());
            if (result)
            {
                await ShowToast($"❌ \"{poiToReject.Name}\" đã bị từ chối.", "#ef4444");
                CloseRejectModal();
                await LoadPois();
                await LoadPendingPois();
            }
        }
    }

    private async Task ShowToast(string message, string color)
    {
        toastMessage = message;
        toastColor = color;
        StateHasChanged();
        await Task.Delay(3000);
        toastMessage = string.Empty;
        StateHasChanged();
    }
}
