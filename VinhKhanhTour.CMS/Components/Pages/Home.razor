@page "/"
@using VinhKhanhTour.Shared.Models
@using VinhKhanhTour.CMS.Services
@inject PoiService PoiService
@inject NavigationManager NavManager

<PageTitle>POI Dashboard</PageTitle>

<div class="dashboard-container page-transition">
    <div class="header-section">
        <h1 class="header-title">POI Management</h1>
        <button class="btn btn-primary" @onclick='() => NavManager.NavigateTo("/poi/new")'>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Add New Location
        </button>
    </div>

    @if (pois == null)
    {
        <div style="text-align: center; padding: 3rem; color: var(--text-secondary);">
            <div style="animation: spin 1s linear infinite; display: inline-block; margin-bottom: 1rem;">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
            </div>
            <p>Loading your stunning locations...</p>
        </div>
    }
    else if (!pois.Any())
    {
        <div class="form-container" style="text-align: center; padding: 4rem 2rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-secondary); margin-bottom: 1rem;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <h2>No Locations Found</h2>
            <p style="color: var(--text-secondary); margin-bottom: 2rem;">Get started by adding your first point of interest to the database.</p>
            <button class="btn btn-primary" @onclick='() => NavManager.NavigateTo("/poi/new")'>Create Location</button>
        </div>
    }
    else
    {
        <div class="poi-grid">
            @foreach (var poi in pois)
            {
                <div class="poi-card" @key="poi.Id">
                    <h3 class="poi-title">@poi.DisplayName</h3>
                    <p class="poi-description">@(string.IsNullOrWhiteSpace(poi.DisplayDescription) ? "No description available." : poi.DisplayDescription)</p>
                    
                    <div class="poi-meta">
                        <div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: -2px; margin-right: 4px;"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"></polygon><line x1="8" y1="2" x2="8" y2="18"></line><line x1="16" y1="6" x2="16" y2="22"></line></svg>
                            @poi.Latitude.ToString("F4"), @poi.Longitude.ToString("F4")
                        </div>
                        <div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: -2px; margin-right: 4px;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                            R: @poi.Radius m
                        </div>
                    </div>

                    <div class="poi-actions">
                        <button class="btn" style="background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.2);" @onclick="() => EditPoi(poi.Id)">
                            Edit
                        </button>
                        <button class="btn btn-danger" @onclick="() => ConfirmDelete(poi)">
                            Delete
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (ShowDeleteConfirm && poiToDelete != null)
{
    <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); display: flex; align-items: center; justify-content: center; z-index: 1000; animation: fadeIn 0.2s;">
        <div class="form-container" style="max-width: 400px; text-align: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            <h3 style="margin-top: 0;">Delete Location?</h3>
            <p style="color: var(--text-secondary); margin-bottom: 2rem;">Are you sure you want to delete "@poiToDelete.Name"? This action cannot be undone.</p>
            <div style="display: flex; gap: 1rem;">
                <button class="btn" style="flex: 1; background: rgba(255,255,255,0.1); color: white; border: none;" @onclick="CancelDelete">Cancel</button>
                <button class="btn btn-danger" style="flex: 1; background: var(--danger); color: white;" @onclick="DeletePoi">Delete</button>
            </div>
        </div>
    </div>
}

<style>
    @@keyframes spin { 100% { transform: rotate(360deg); } }
</style>

@code {
    private List<Poi>? pois;
    private bool ShowDeleteConfirm = false;
    private Poi? poiToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadPois();
    }

    private async Task LoadPois()
    {
        try
        {
            pois = await PoiService.GetPoisAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading POIs: {ex.Message}");
        }
    }

    private void EditPoi(int id)
    {
        NavManager.NavigateTo($"/poi/edit/{id}");
    }

    private void ConfirmDelete(Poi poi)
    {
        poiToDelete = poi;
        ShowDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        ShowDeleteConfirm = false;
        poiToDelete = null;
    }

    private async Task DeletePoi()
    {
        if (poiToDelete != null)
        {
            await PoiService.DeletePoiAsync(poiToDelete.Id);
            await LoadPois();
        }
        CancelDelete();
    }
}
