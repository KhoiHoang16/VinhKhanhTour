@page "/qrcode"
@using VinhKhanhTour.Shared.Models
@using VinhKhanhTour.CMS.Services
@inject PoiService PoiService
@inject NavigationManager NavManager

<PageTitle>QR Code Kích hoạt Nội dung - VinhKhanh Tour</PageTitle>

<div class="dashboard-container page-transition">
    <div class="header-section">
        <h1 class="header-title">📱 QR Code Kích hoạt Nội dung</h1>
    </div>

    <div class="poi-card" style="margin-bottom: 1.5rem; background: linear-gradient(135deg, rgba(249, 115, 22, 0.15), rgba(251, 191, 36, 0.1));">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <div style="font-size: 2.5rem;">📱</div>
            <div>
                <h3 style="margin: 0; color: var(--text-primary); font-size: 1.1rem;">Quét QR Code = Nghe ngay!</h3>
                <p style="margin: 0.25rem 0 0; color: var(--text-secondary); font-size: 0.9rem;">
                    Đặt mã QR tại 3 trạm xe buýt: <strong style="color: var(--primary-color);">Khánh Hội</strong>, 
                    <strong style="color: var(--primary-color);">Vĩnh Hội</strong>, 
                    <strong style="color: var(--primary-color);">Xóm Chiếu</strong>. 
                    Du khách quét mã để nghe nội dung ngay — <strong>không cần GPS</strong>.
                </p>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div style="text-align: center; padding: 3rem; color: var(--text-secondary);">
            <div class="loading-spinner">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
            </div>
            <p class="loading-pulse">Đang tải dữ liệu...</p>
        </div>
    }
    else
    {
        @foreach (var stop in busStops)
        {
            <div style="margin-bottom: 2rem;">
                <div class="bus-stop-header">
                    🚌 @stop.Name
                </div>
                <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1.25rem; padding-left: 0.25rem;">
                    @stop.Description
                </p>

                @{
                    var stopPois = pois.Where(p => stop.AssociatedPoiIds.Contains(p.Id)).ToList();
                }

                @if (!stopPois.Any())
                {
                    <div class="poi-card" style="text-align: center; padding: 2rem; color: var(--text-secondary);">
                        Không có địa điểm nào liên kết với trạm này.
                    </div>
                }
                else
                {
                    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem;">
                        @foreach (var poi in stopPois)
                        {
                            var qrUrl = $"{baseUrl}/api/poi/qr/{poi.Id}?stop={stop.Id}";
                            <div class="qr-card" @key="@($"{stop.Id}_{poi.Id}")">
                                <h4 style="margin: 0 0 0.25rem; color: var(--text-primary); font-size: 1rem; font-weight: 700;">@poi.Name</h4>
                                <p style="color: var(--text-secondary); font-size: 0.82rem; margin: 0 0 1rem;">
                                    @(string.IsNullOrWhiteSpace(poi.Description) ? "Quét để nghe thông tin." : (poi.Description.Length > 60 ? poi.Description.Substring(0, 60) + "..." : poi.Description))
                                </p>

                                <!-- QR Code SVG -->
                                <div class="qr-image">
                                    @((MarkupString)GenerateQrSvg(qrUrl, poi.Name))
                                </div>

                                <div style="margin-top: 0.5rem;">
                                    <span class="badge badge-primary" style="font-size: 0.75rem;">POI #@poi.Id</span>
                                    @if (!string.IsNullOrWhiteSpace(poi.AudioUrlVi))
                                    {
                                        <span class="badge badge-success" style="font-size: 0.75rem;">🎵 Audio VI</span>
                                    }
                                </div>

                                <div style="margin-top: 0.75rem; font-size: 0.75rem; color: var(--text-secondary); word-break: break-all; background: rgba(0,0,0,0.2); padding: 0.5rem; border-radius: 0.4rem;">
                                    @qrUrl
                                </div>

                                <div style="margin-top: 0.75rem; display: flex; gap: 0.5rem; justify-content: center;">
                                    <button class="btn btn-secondary" style="padding: 0.3rem 0.7rem; font-size: 0.8rem;" @onclick="() => CopyUrl(qrUrl)">
                                        📋 Sao chép URL
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        <!-- Instructions -->
        <div class="poi-card" style="margin-top: 1rem;">
            <h3 style="margin-top: 0; margin-bottom: 1rem; font-weight: 700; font-size: 1.05rem;">📋 Hướng dẫn Sử dụng QR Code</h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">
                <div style="text-align: center; padding: 1rem;">
                    <div style="font-size: 2rem; margin-bottom: 0.5rem;">1️⃣</div>
                    <h4 style="margin: 0 0 0.5rem; color: var(--primary-color);">In mã QR</h4>
                    <p style="color: var(--text-secondary); font-size: 0.85rem; margin: 0;">In các mã QR ở trên và dán tại trạm xe buýt tương ứng.</p>
                </div>
                <div style="text-align: center; padding: 1rem;">
                    <div style="font-size: 2rem; margin-bottom: 0.5rem;">2️⃣</div>
                    <h4 style="margin: 0 0 0.5rem; color: var(--primary-color);">Du khách quét mã</h4>
                    <p style="color: var(--text-secondary); font-size: 0.85rem; margin: 0;">Du khách dùng camera điện thoại quét mã QR tại điểm dừng.</p>
                </div>
                <div style="text-align: center; padding: 1rem;">
                    <div style="font-size: 2rem; margin-bottom: 0.5rem;">3️⃣</div>
                    <h4 style="margin: 0 0 0.5rem; color: var(--primary-color);">Nghe ngay - Không cần GPS</h4>
                    <p style="color: var(--text-secondary); font-size: 0.85rem; margin: 0;">App mở nội dung POI và phát audio ngay lập tức, không yêu cầu GPS.</p>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<Poi> pois = new();
    private List<BusStop> busStops = new();
    private string baseUrl = "";

    protected override async Task OnInitializedAsync()
    {
        baseUrl = NavManager.BaseUri.TrimEnd('/');
        busStops = BusStop.GetBusStops();
        pois = await PoiService.GetPoisAsync();
        isLoading = false;
    }

    private void CopyUrl(string url)
    {
        // In Blazor Server, JS interop would be used to copy.
        // For now we just show the URL visually.
    }

    /// <summary>
    /// Generates a simple QR-like SVG pattern (decorative representation).
    /// In production, use a proper QR library like QRCoder.
    /// </summary>
    private string GenerateQrSvg(string data, string label)
    {
        // Generate a deterministic pattern based on the data string hash
        int hash = Math.Abs(data.GetHashCode());
        var rng = new Random(hash);
        int size = 21; // QR v1 is 21x21
        int cellSize = 6;
        int totalSize = size * cellSize;

        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 {totalSize} {totalSize}' width='150' height='150'>");
        
        // Background
        sb.Append($"<rect width='{totalSize}' height='{totalSize}' fill='white'/>");

        // Corner finder patterns (top-left, top-right, bottom-left)
        DrawFinderPattern(sb, 0, 0, cellSize);
        DrawFinderPattern(sb, (size - 7) * cellSize, 0, cellSize);
        DrawFinderPattern(sb, 0, (size - 7) * cellSize, cellSize);

        // Data modules
        for (int row = 0; row < size; row++)
        {
            for (int col = 0; col < size; col++)
            {
                // Skip finder pattern areas
                if ((row < 8 && col < 8) || (row < 8 && col >= size - 8) || (row >= size - 8 && col < 8))
                    continue;

                if (rng.Next(100) < 45)
                {
                    sb.Append($"<rect x='{col * cellSize}' y='{row * cellSize}' width='{cellSize}' height='{cellSize}' fill='#1C1917'/>");
                }
            }
        }

        sb.Append("</svg>");
        return sb.ToString();
    }

    private void DrawFinderPattern(System.Text.StringBuilder sb, int x, int y, int cellSize)
    {
        // Outer border
        sb.Append($"<rect x='{x}' y='{y}' width='{7 * cellSize}' height='{7 * cellSize}' fill='#1C1917'/>");
        // White inner
        sb.Append($"<rect x='{x + cellSize}' y='{y + cellSize}' width='{5 * cellSize}' height='{5 * cellSize}' fill='white'/>");
        // Center square
        sb.Append($"<rect x='{x + 2 * cellSize}' y='{y + 2 * cellSize}' width='{3 * cellSize}' height='{3 * cellSize}' fill='#F97316'/>");
    }
}
