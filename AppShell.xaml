<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VinhKhanhTour.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:VinhKhanhTour.Pages"
    Shell.FlyoutBehavior="Disabled"
    Title="VinhKhanhTour">

    <TabBar>
        <Tab Title="Trang chủ" Icon="{StaticResource IconDashboard}">
            <ShellContent ContentTemplate="{DataTemplate pages:MainPage}" Route="main" />
        </Tab>

        <Tab Title="Bản đồ" Icon="{StaticResource IconProjects}">
            <ShellContent ContentTemplate="{DataTemplate pages:MapPage}" Route="map" />
        </Tab>

        <Tab Title="Cài đặt" Icon="{StaticResource IconMeta}">
            <ShellContent ContentTemplate="{DataTemplate pages:SettingsPage}" Route="settings" />
        </Tab>
    </TabBar>

</Shell>
