<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTour.Pages.SettingsPage"
             Title="Cài đặt"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBackground}, Dark={StaticResource DarkBackground}}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20">
            
            <!-- 🎨 Giao diện Section -->
            <HorizontalStackLayout Spacing="8" Margin="0,4,0,0">
                <Label Text="🎨" FontSize="20" VerticalOptions="Center" />
                <Label Text="Giao diện" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
            </HorizontalStackLayout>
            
            <Border Style="{StaticResource CardStyle}">
                <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                    <Label Text="🌙" FontSize="22" VerticalOptions="Center" />
                    <Label Text="Chế độ Tối (Dark Mode)" VerticalOptions="Center" HorizontalOptions="FillAndExpand" />
                    <Switch x:Name="ThemeSwitch" Toggled="OnThemeSwitchToggled" 
                            HorizontalOptions="End"
                            OnColor="{StaticResource Primary}" />
                </HorizontalStackLayout>
            </Border>

            <!-- 🔊 Âm thanh Section -->
            <HorizontalStackLayout Spacing="8" Margin="0,8,0,0">
                <Label Text="🔊" FontSize="20" VerticalOptions="Center" />
                <Label Text="Âm thanh &amp; Giọng đọc" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Tốc độ đọc (TTS)" FontAttributes="Bold" />
                    <Slider x:Name="SpeechRateSlider" 
                            Maximum="2.0" Minimum="0.5" Value="1.0" 
                            ValueChanged="OnSpeechRateChanged"
                            MinimumTrackColor="{StaticResource Primary}"
                            MaximumTrackColor="{StaticResource Gray200}"
                            ThumbColor="{StaticResource Primary}" />
                    <Label x:Name="SpeechRateLabel" 
                           Text="Bình thường (1.0x)" 
                           FontSize="12" TextColor="{StaticResource Gray400}" 
                           HorizontalOptions="End" />
                </VerticalStackLayout>
            </Border>

            <!-- ℹ️ About Section -->
            <HorizontalStackLayout Spacing="8" Margin="0,8,0,0">
                <Label Text="ℹ️" FontSize="20" VerticalOptions="Center" />
                <Label Text="Về ứng dụng" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
            </HorizontalStackLayout>
            
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="🦀" FontSize="28" VerticalOptions="Center" />
                        <VerticalStackLayout>
                            <Label Text="Vĩnh Khánh Tour" FontSize="18" FontAttributes="Bold" />
                            <Label Text="Phiên bản 1.0.0" FontSize="12" TextColor="{StaticResource Gray400}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}" Margin="0,4" />
                    <Label Text="Đồ án môn học — Xây dựng ứng dụng di động" FontSize="13" TextColor="{StaticResource Gray400}" />
                    <Label Text="Thiết kế ❤️ bởi đội ngũ phát triển" FontSize="12" TextColor="{StaticResource Gray300}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
