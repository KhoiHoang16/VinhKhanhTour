<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTour.Pages.RegisterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0f172a">

    <Grid>
        <!-- Tấm nền Background phong cách Phố Đêm Vĩnh Khánh -->
        <Image Source="vinh_khanh_food_street_banner.jpg" 
               Aspect="AspectFill" 
               Opacity="0.45"/>
               
        <!-- Lớp phủ Gradient đen quyền lực từ dưới lên để tôn giao diện -->
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#50000000" Offset="0.0" />
                    <GradientStop Color="#E60F172A" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView>
            <Grid VerticalOptions="Center" Padding="24,0">
                <VerticalStackLayout Spacing="32" 
                                     VerticalOptions="Center" 
                                     HorizontalOptions="Fill"
                                     MaximumWidthRequest="400">
                
                    <!-- Headers -->
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="📝" FontSize="56" HorizontalOptions="Center" Margin="0,0,0,10" />
                        <Label Text="Đăng ký tài khoản" 
                               FontSize="30" 
                               FontFamily="OpenSansSemibold" 
                               TextColor="#ffffff" 
                               HorizontalOptions="Center" />
                        <Label Text="Gia nhập cộng đồng ẩm thực Vĩnh Khánh" 
                               FontSize="14" 
                               TextColor="#94a3b8" 
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                <!-- Premium Dark Container -->
                <Border StrokeShape="RoundRectangle 28" 
                        StrokeThickness="1" 
                        Stroke="#25ffffff"
                        Background="#1e293b"
                        HorizontalOptions="Fill"
                        Padding="25,35">

                    <VerticalStackLayout Spacing="22" HorizontalOptions="Fill">
                        
                        <!-- Input Box: Full Name -->
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Fill">
                            <Label Text="HỌ &amp; TÊN" TextColor="#cbd5e1" FontSize="13" FontFamily="OpenSansSemibold" CharacterSpacing="1" />
                            <Border StrokeShape="RoundRectangle 14" 
                                    StrokeThickness="1"
                                    Stroke="#30ffffff"
                                    Background="#0f172a"
                                    HorizontalOptions="Fill"
                                    HeightRequest="55"
                                    Padding="18,0">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="👤" FontSize="16" VerticalOptions="Center" Margin="0,0,12,0"/>
                                    <!-- BackgroundColor="Transparent" để vô hiệu hóa dải nền trắng -->
                                    <Entry Grid.Column="1" 
                                           x:Name="FullNameEntry"
                                           Placeholder="Nhập họ và tên" 
                                           PlaceholderColor="#64748b"
                                           TextColor="#f8fafc"
                                           BackgroundColor="Transparent"
                                           FontSize="15"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Input Box: Email -->
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Fill">
                            <Label Text="EMAIL" TextColor="#cbd5e1" FontSize="13" FontFamily="OpenSansSemibold" CharacterSpacing="1" />
                            <Border StrokeShape="RoundRectangle 14" 
                                    StrokeThickness="1"
                                    Stroke="#30ffffff"
                                    Background="#0f172a"
                                    HorizontalOptions="Fill"
                                    HeightRequest="55"
                                    Padding="18,0">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="✉️" FontSize="16" VerticalOptions="Center" Margin="0,0,12,0"/>
                                    <Entry Grid.Column="1" 
                                           x:Name="EmailEntry"
                                           Placeholder="Nhập email của bạn" 
                                           PlaceholderColor="#64748b"
                                           TextColor="#f8fafc"
                                           BackgroundColor="Transparent"
                                           Keyboard="Email"
                                           FontSize="15"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Input Box: Password -->
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Fill">
                            <Label Text="MẬT KHẨU" TextColor="#cbd5e1" FontSize="13" FontFamily="OpenSansSemibold" CharacterSpacing="1" />
                            <Border StrokeShape="RoundRectangle 14" 
                                    StrokeThickness="1"
                                    Stroke="#30ffffff"
                                    Background="#0f172a"
                                    HorizontalOptions="Fill"
                                    HeightRequest="55"
                                    Padding="18,0">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Label Grid.Column="0" Text="🔒" FontSize="16" VerticalOptions="Center" Margin="0,0,12,0"/>
                                    <Entry Grid.Column="1" 
                                           x:Name="PasswordEntry"
                                           Placeholder="Nhập mật khẩu" 
                                           PlaceholderColor="#64748b"
                                           TextColor="#f8fafc"
                                           BackgroundColor="Transparent"
                                           IsPassword="True"
                                           FontSize="15"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="2" 
                                           x:Name="EyeIcon"
                                           Text="👁️" 
                                           FontSize="18"
                                           Opacity="0.7"
                                           VerticalOptions="Center" 
                                           HorizontalOptions="End">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTogglePasswordVisibility" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Input Box: Confirm Password -->
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Fill">
                            <Label Text="XÁC NHẬN MẬT KHẨU" TextColor="#cbd5e1" FontSize="13" FontFamily="OpenSansSemibold" CharacterSpacing="1" />
                            <Border StrokeShape="RoundRectangle 14" 
                                    StrokeThickness="1"
                                    Stroke="#30ffffff"
                                    Background="#0f172a"
                                    HorizontalOptions="Fill"
                                    HeightRequest="55"
                                    Padding="18,0">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Label Grid.Column="0" Text="✅" FontSize="16" VerticalOptions="Center" Margin="0,0,12,0"/>
                                    <Entry Grid.Column="1" 
                                           x:Name="ConfirmPasswordEntry"
                                           Placeholder="Nhập lại mật khẩu" 
                                           PlaceholderColor="#64748b"
                                           TextColor="#f8fafc"
                                           BackgroundColor="Transparent"
                                           IsPassword="True"
                                           FontSize="15"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="2" 
                                           x:Name="ConfirmEyeIcon"
                                           Text="👁️" 
                                           FontSize="18"
                                           Opacity="0.7"
                                           VerticalOptions="Center" 
                                           HorizontalOptions="End">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnToggleConfirmPasswordVisibility" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Spinner -->
                        <ActivityIndicator x:Name="LoadingSpinner" 
                                           IsRunning="False" 
                                           IsVisible="False" 
                                           Color="#10b981" 
                                           HorizontalOptions="Center" />

                        <!-- Nút Action chính -->
                        <Button x:Name="RegisterBtn"
                                Text="Tạo Tài Khoản" 
                                FontFamily="OpenSansSemibold"
                                FontSize="17"
                                TextColor="White"
                                Background="#f97316"
                                CornerRadius="28"
                                HorizontalOptions="Fill"
                                HeightRequest="56"
                                Margin="0,15,0,0"
                                Clicked="OnRegisterClicked" />
                                
                    </VerticalStackLayout>
                </Border>

                <!-- Điều hướng Footer Back to Login -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,10,0,0">
                    <Label Text="Bạn đã có tài khoản?" TextColor="#cbd5e1" FontSize="15" />
                    <Label Text="Đăng nhập" 
                           TextColor="#10b981" 
                           FontSize="15" 
                           FontFamily="OpenSansSemibold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackToLoginTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
